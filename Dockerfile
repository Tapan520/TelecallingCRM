# ?? Stage 1: Build ????????????????????????????????????????????????????????????
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Copy project file and restore dependencies first (layer-cache friendly)
COPY TelecallingCRM.csproj ./
RUN dotnet restore TelecallingCRM.csproj

# Copy everything else and publish
COPY . .
RUN dotnet publish TelecallingCRM.csproj \
    -c Release \
    -o /app/publish \
    --no-restore \
    /p:UseAppHost=false

# ?? Stage 2: Runtime ??????????????????????????????????????????????????????????
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app

# Install curl for Railway health-check probes
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

# Copy published output
COPY --from=build /app/publish .

# Railway injects PORT at runtime; ASP.NET Core reads ASPNETCORE_HTTP_PORTS
ENV ASPNETCORE_HTTP_PORTS=8080
ENV ASPNETCORE_ENVIRONMENT=Production

EXPOSE 8080

ENTRYPOINT ["dotnet", "TelecallingCRM.dll"]
