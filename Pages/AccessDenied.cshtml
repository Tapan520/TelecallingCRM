@page
@{
    Layout = null;
    ViewData["Title"] = "Access Denied";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Access Denied – TelecallingCRM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background: linear-gradient(135deg,#1e1b4b 0%,#312e81 60%,#4338ca 100%); min-height:100vh; display:flex; align-items:center; justify-content:center; }
    </style>
</head>
<body>
    <div class="text-center text-white px-4">
        <i class="bi bi-shield-lock-fill" style="font-size:4rem;color:#f87171;"></i>
        <h1 class="mt-3 fw-bold">Access Denied</h1>
        <p class="text-indigo-200 mt-2 mb-4" style="opacity:.8;">You don't have permission to access this page.</p>
        <a href="/Dashboard" class="btn btn-light px-4">
            <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
        </a>
    </div>
</body>
</html>
