@page
@model TelecallingCRM.Pages.ResetPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Reset Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password - TelecallingCRM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background: linear-gradient(135deg,#1e1b4b 0%,#312e81 60%,#4338ca 100%); min-height:100vh; display:flex; align-items:center; justify-content:center; }
        .card { border-radius:1rem; padding:2.5rem; width:100%; max-width:420px; box-shadow:0 20px 60px rgba(0,0,0,0.3); }
        .btn-primary { background:#4f46e5; border-color:#4f46e5; }
    </style>
</head>
<body>
    <div class="card bg-white">
        <h4 class="fw-bold mb-4">Set New Password</h4>
        @if (Model.ResetDone)
        {
            <div class="alert alert-success">Password reset successful!</div>
            <a href="/Login" class="btn btn-primary w-100">Sign In</a>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            { <div class="alert alert-danger">@Model.ErrorMessage</div> }
            <form method="post">
                <input type="hidden" asp-for="Input.Token" />
                <input type="hidden" asp-for="Input.Email" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">New Password</label>
                    <input asp-for="Input.NewPassword" type="password" class="form-control" />
                    <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Confirm Password</label>
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control" />
                </div>
                <button type="submit" class="btn btn-primary w-100">Reset Password</button>
            </form>
        }
    </div>
</body>
</html>
