@page
@model TelecallingCRM.Pages.ForgotPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - TelecallingCRM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background: linear-gradient(135deg,#1e1b4b 0%,#312e81 60%,#4338ca 100%); min-height:100vh; display:flex; align-items:center; justify-content:center; }
        .card { border-radius:1rem; padding:2.5rem; width:100%; max-width:420px; box-shadow:0 20px 60px rgba(0,0,0,0.3); }
        .brand { font-size:1.5rem; font-weight:800; color:#4f46e5; margin-bottom:0.25rem; }
        .btn-primary { background:#4f46e5; border-color:#4f46e5; }
        .btn-primary:hover { background:#3730a3; border-color:#3730a3; }
    </style>
</head>
<body>
    <div class="card bg-white">
        <div class="brand"><i class="bi bi-telephone-fill"></i> TelecallingCRM</div>
        <p class="text-muted mb-4" style="font-size:0.875rem;">Reset your password</p>

        @if (Model.EmailSent)
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle-fill me-2"></i>
                If that email exists, a reset link has been sent. Check your inbox.
            </div>
            <a href="/Login" class="btn btn-outline-primary w-100">Back to Sign In</a>
        }
        else
        {
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger">@Model.ErrorMessage</div>
            }
            <form method="post">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Email Address</label>
                    <input asp-for="Input.Email" class="form-control" placeholder="you@company.com" autocomplete="email" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2">Send Reset Link</button>
            </form>
            <div class="text-center mt-3">
                <a href="/Login" class="text-muted small">Back to Sign In</a>
            </div>
        }
    </div>
</body>
</html>
