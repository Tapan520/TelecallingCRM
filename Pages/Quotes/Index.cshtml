@page
@model TelecallingCRM.Pages.Quotes.IndexModel
@{
    ViewData["Title"] = "Quotations";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-file-earmark-text text-primary me-2"></i>Quotations</h5>
    <button class="btn btn-primary btn-sm" onclick="openQuoteModal()"><i class="bi bi-plus-lg me-1"></i>New Quote</button>
</div>

<div class="card">
    <div class="card-header d-flex gap-2">
        <select class="form-select form-select-sm w-auto" id="filterStatus" onchange="loadQuotes()">
            <option value="">All Status</option>
            <option>Draft</option><option>Sent</option><option>Accepted</option><option>Rejected</option><option>Expired</option>
        </select>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Quote #</th><th>Title</th><th>Lead</th><th>Total</th><th>Status</th><th>Expires</th><th>Created</th><th></th></tr>
            </thead>
            <tbody id="quotes-tbody">
                <tr><td colspan="8" class="text-center text-muted py-4"><div class="spinner-border spinner-border-sm"></div></td></tr>
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center" id="pager"></div>
</div>

<!-- Modal -->
<div class="modal fade" id="quoteModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title" id="quoteModalTitle">New Quote</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <input type="hidden" id="quoteId" />
                <div class="row g-3 mb-3">
                    <div class="col-md-6"><label class="form-label">Title</label><input type="text" class="form-control" id="qTitle" /></div>
                    <div class="col-md-6">
                        <label class="form-label">Lead *</label>
                        <div class="position-relative">
                            <input type="text" class="form-control" id="qLeadSearch" placeholder="Search lead name or phone..." autocomplete="off" oninput="searchLeadForQuote(this.value)">
                            <input type="hidden" id="qLeadId">
                            <div id="qLeadSuggestions" class="list-group position-absolute w-100" style="z-index:1050;max-height:180px;overflow-y:auto;display:none;"></div>
                        </div>
                    </div>
                </div>
                <div id="line-items">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <strong class="small">Line Items</strong>
                        <button class="btn btn-outline-secondary btn-sm" onclick="addLineItem()"><i class="bi bi-plus"></i> Add Row</button>
                    </div>
                    <table class="table table-sm border mb-2">
                        <thead class="table-light"><tr><th>Description</th><th>Qty</th><th>Unit Price</th><th>Amount</th><th></th></tr></thead>
                        <tbody id="line-items-body"></tbody>
                    </table>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-md-3"><label class="form-label">Subtotal</label><input type="number" class="form-control" id="qSubtotal" readonly /></div>
                    <div class="col-md-3"><label class="form-label">Discount</label><input type="number" class="form-control" id="qDiscount" value="0" oninput="calcTotals()" /></div>
                    <div class="col-md-3"><label class="form-label">Tax %</label><input type="number" class="form-control" id="qTax" value="18" oninput="calcTotals()" /></div>
                    <div class="col-md-3"><label class="form-label">Total</label><input type="number" class="form-control" id="qTotal" readonly /></div>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-md-6"><label class="form-label">Expires At</label><input type="date" class="form-control" id="qExpiry" /></div>
                    <div class="col-md-6"><label class="form-label">Notes</label><input type="text" class="form-control" id="qNotes" /></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary btn-sm" onclick="saveQuote()">Save Quote</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let currentPage = 1;
const pageSize = 25;
let lineItems = [];
let currentUserId = '@Model.CurrentUserId';
let qLeadTimer;

function searchLeadForQuote(q) {
    clearTimeout(qLeadTimer);
    const box = document.getElementById('qLeadSuggestions');
    if (q.length < 2) { box.style.display = 'none'; return; }
    qLeadTimer = setTimeout(async () => {
        const res = await fetch(`/api/leads?q=${encodeURIComponent(q)}&pageSize=8`);
        if (!res.ok) return;
        const d = await res.json();
        const leads = d.leads ?? [];
        if (!leads.length) { box.style.display = 'none'; return; }
        box.innerHTML = leads.map(l =>
            `<a href="javascript:void(0)" class="list-group-item list-group-item-action small"
               onclick="selectLeadForQuote('${l.id}','${l.name}','${l.phone}')">
               ${l.name} <span class="text-muted">${l.phone}</span>
             </a>`).join('');
        box.style.display = 'block';
    }, 280);
}

function selectLeadForQuote(id, name, phone) {
    document.getElementById('qLeadId').value = id;
    document.getElementById('qLeadSearch').value = `${name} — ${phone}`;
    document.getElementById('qLeadSuggestions').style.display = 'none';
}

async function loadQuotes(page = 1) {
    currentPage = page;
    const status = document.getElementById('filterStatus').value;
    const res = await fetch(`/api/quotes?page=${page}&pageSize=${pageSize}${status?'&status='+status:''}`);
    if (!res.ok) return;
    const d = await res.json();
    const statusBadge = s => ({ Draft:'secondary', Sent:'primary', Accepted:'success', Rejected:'danger', Expired:'warning' }[s]||'secondary');
    document.getElementById('quotes-tbody').innerHTML = d.items.length === 0
        ? '<tr><td colspan="8" class="text-center text-muted py-4">No quotes found.</td></tr>'
        : d.items.map(q => `<tr>
            <td class="fw-semibold">${q.quoteNumber}</td>
            <td>${q.title||'-'}</td>
            <td>${q.leadName}</td>
            <td class="fw-semibold">&#8377;${Number(q.total).toLocaleString('en-IN')}</td>
            <td><span class="badge bg-${statusBadge(q.status)}">${q.status}</span></td>
            <td>${q.expiresAt ? new Date(q.expiresAt).toLocaleDateString() : '-'}</td>
            <td>${new Date(q.createdAt).toLocaleDateString()}</td>
            <td>
                <button class="btn btn-sm btn-outline-secondary me-1" onclick="editQuote('${q.id}')"><i class="bi bi-pencil"></i></button>
                <button class="btn btn-sm btn-outline-danger" onclick="deleteQuote('${q.id}')"><i class="bi bi-trash"></i></button>
            </td>
        </tr>`).join('');
    const pager = document.getElementById('pager');
    pager.innerHTML = `<small class="text-muted">Showing ${d.items.length} of ${d.total}</small>
        <div>${page>1?`<button class="btn btn-sm btn-outline-secondary me-1" onclick="loadQuotes(${page-1})">Prev</button>`:''}
        ${d.total > page*pageSize?`<button class="btn btn-sm btn-outline-secondary" onclick="loadQuotes(${page+1})">Next</button>`:''}</div>`;
}

function addLineItem(item = null) {
    const i = lineItems.length;
    lineItems.push(item || { description: '', qty: 1, unitPrice: 0, amount: 0 });
    const tr = document.createElement('tr');
    tr.id = `li-${i}`;
    tr.innerHTML = `
        <td><input type="text" class="form-control form-control-sm" id="ldesc-${i}" value="${lineItems[i].description}" oninput="updateLine(${i})" /></td>
        <td><input type="number" class="form-control form-control-sm" id="lqty-${i}" value="${lineItems[i].qty}" min="1" oninput="updateLine(${i})" style="width:70px" /></td>
        <td><input type="number" class="form-control form-control-sm" id="lup-${i}" value="${lineItems[i].unitPrice}" oninput="updateLine(${i})" style="width:100px" /></td>
        <td id="lamt-${i}" class="fw-semibold">&#8377;${lineItems[i].amount.toLocaleString('en-IN')}</td>
        <td><button class="btn btn-sm btn-outline-danger" onclick="removeLine(${i})"><i class="bi bi-x"></i></button></td>`;
    document.getElementById('line-items-body').appendChild(tr);
}

function updateLine(i) {
    const qty = parseFloat(document.getElementById(`lqty-${i}`)?.value || 0);
    const up = parseFloat(document.getElementById(`lup-${i}`)?.value || 0);
    const amount = qty * up;
    lineItems[i].description = document.getElementById(`ldesc-${i}`)?.value;
    lineItems[i].qty = qty; lineItems[i].unitPrice = up; lineItems[i].amount = amount;
    document.getElementById(`lamt-${i}`).textContent = '&#8377;' + amount.toLocaleString('en-IN');
    calcTotals();
}

function removeLine(i) {
    document.getElementById(`li-${i}`)?.remove();
    lineItems[i] = null;
    calcTotals();
}

function calcTotals() {
    const sub = lineItems.filter(Boolean).reduce((s, l) => s + l.amount, 0);
    const disc = parseFloat(document.getElementById('qDiscount')?.value || 0);
    const tax = parseFloat(document.getElementById('qTax')?.value || 18);
    const total = (sub - disc) * (1 + tax / 100);
    document.getElementById('qSubtotal').value = sub.toFixed(2);
    document.getElementById('qTotal').value = total.toFixed(2);
}

function openQuoteModal() {
    document.getElementById('quoteId').value = '';
    document.getElementById('qTitle').value = '';
    document.getElementById('qLeadId').value = '';
    document.getElementById('qLeadSearch').value = '';
    document.getElementById('qLeadSuggestions').style.display = 'none';
    document.getElementById('qDiscount').value = '0';
    document.getElementById('qTax').value = '18';
    document.getElementById('qSubtotal').value = '0';
    document.getElementById('qTotal').value = '0';
    document.getElementById('qExpiry').value = '';
    document.getElementById('qNotes').value = '';
    document.getElementById('line-items-body').innerHTML = '';
    lineItems = [];
    document.getElementById('quoteModalTitle').textContent = 'New Quote';
    new bootstrap.Modal(document.getElementById('quoteModal')).show();
}

async function editQuote(id) {
    const res = await fetch(`/api/quotes/${id}`);
    if (!res.ok) return;
    const q = await res.json();
    document.getElementById('quoteId').value = q.id;
    document.getElementById('qTitle').value = q.title || '';
    document.getElementById('qLeadId').value = q.leadId;
    // Fetch lead name for display
    const lRes = await fetch(`/api/leads/${q.leadId}`);
    if (lRes.ok) { const l = await lRes.json(); document.getElementById('qLeadSearch').value = `${l.name} — ${l.phone}`; }
    else { document.getElementById('qLeadSearch').value = q.leadId; }
    document.getElementById('qLeadSuggestions').style.display = 'none';
    document.getElementById('qDiscount').value = q.discountAmount;
    document.getElementById('qTax').value = q.taxPercent;
    document.getElementById('qExpiry').value = q.expiresAt ? q.expiresAt.split('T')[0] : '';
    document.getElementById('qNotes').value = q.notes || '';
    document.getElementById('line-items-body').innerHTML = '';
    lineItems = [];
    (JSON.parse(q.lineItemsJson || '[]')).forEach(l => addLineItem(l));
    calcTotals();
    document.getElementById('quoteModalTitle').textContent = 'Edit Quote';
    new bootstrap.Modal(document.getElementById('quoteModal')).show();
}

async function saveQuote() {
    const id = document.getElementById('quoteId').value;
    const body = {
        title: document.getElementById('qTitle').value,
        leadId: document.getElementById('qLeadId').value,
        createdById: currentUserId,
        subTotal: parseFloat(document.getElementById('qSubtotal').value || 0),
        discountAmount: parseFloat(document.getElementById('qDiscount').value || 0),
        taxPercent: parseFloat(document.getElementById('qTax').value || 18),
        notes: document.getElementById('qNotes').value,
        lineItemsJson: JSON.stringify(lineItems.filter(Boolean)),
        currency: 'INR',
        expiresAt: document.getElementById('qExpiry').value || null,
        dealId: null
    };
    const url = id ? `/api/quotes/${id}` : '/api/quotes';
    const method = id ? 'PUT' : 'POST';
    const res = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
    if (res.ok) { bootstrap.Modal.getInstance(document.getElementById('quoteModal'))?.hide(); loadQuotes(); }
    else alert('Failed to save quote.');
}

async function deleteQuote(id) {
    if (!confirm('Delete this quote?')) return;
    await fetch(`/api/quotes/${id}`, { method: 'DELETE' });
    loadQuotes();
}

loadQuotes();
</script>
}
