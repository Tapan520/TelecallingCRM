@page
@model TelecallingCRM.Pages.SuperAdmin.AllUsersModel
@{
    ViewData["Title"] = "All Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-0 fw-bold">All Users</h5>
        <small class="text-muted">Every user across all tenants</small>
    </div>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#saUserModal" onclick="openNewUser()">
        <i class="bi bi-person-plus"></i> Add User
    </button>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Email</th><th>Phone</th><th>Role</th><th>Tenant</th><th>Last Login</th><th>Status</th><th></th></tr>
            </thead>
            <tbody id="allusers-tbody">
                <tr><td colspan="8" class="text-center text-muted py-4">Loading...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Add / Edit User Modal -->
<div class="modal fade" id="saUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="saUserModalTitle">Add User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="sa-user-id">
                <div class="mb-3">
                    <label class="form-label">Full Name *</label>
                    <input type="text" id="sa-user-name" class="form-control">
                </div>
                <div class="mb-3">
                    <label class="form-label">Email *</label>
                    <input type="email" id="sa-user-email" class="form-control">
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone</label>
                    <input type="text" id="sa-user-phone" class="form-control">
                </div>
                <div class="mb-3">
                    <label class="form-label">Role</label>
                    <select id="sa-user-role" class="form-select">
                        <option value="agent">Agent</option>
                        <option value="manager">Manager</option>
                        <option value="admin">Admin</option>
                    </select>
                </div>
                <div class="mb-3" id="sa-tenant-group">
                    <label class="form-label">Tenant *</label>
                    <select id="sa-user-tenant" class="form-select">
                        <option value="">Select tenant…</option>
                    </select>
                </div>
                <div class="mb-3" id="sa-password-group">
                    <label class="form-label">Temporary Password *</label>
                    <input type="password" id="sa-user-password" class="form-control">
                </div>
                <div class="mb-3" id="sa-newpassword-group" style="display:none">
                    <label class="form-label">New Password <span class="text-muted small">(leave blank to keep current)</span></label>
                    <input type="password" id="sa-user-newpassword" class="form-control" placeholder="Enter new password">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveSaUser()">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const roleColors = { superadmin:'dark', admin:'danger', manager:'warning', agent:'primary' };
let allTenants = [];

async function load() {
let res;
try {
    res = await fetch('/api/superadmin/users');
} catch (e) {
    document.getElementById('allusers-tbody').innerHTML = `<tr><td colspan="8" class="text-center text-danger py-4">Network error: ${e.message}</td></tr>`;
    return;
}
if (!res.ok) {
    document.getElementById('allusers-tbody').innerHTML = `<tr><td colspan="8" class="text-center text-danger py-4">Failed to load users (HTTP ${res.status}). Please refresh the page.</td></tr>`;
    return;
}
let data;
try {
    data = await res.json();
} catch (e) {
    document.getElementById('allusers-tbody').innerHTML = `<tr><td colspan="8" class="text-center text-danger py-4">Unexpected server response. Please refresh the page.</td></tr>`;
    return;
}
    if (data.length === 0) {
        document.getElementById('allusers-tbody').innerHTML = `<tr><td colspan="8" class="text-center text-muted py-4">No users found.</td></tr>`;
    } else {
        document.getElementById('allusers-tbody').innerHTML = data.map(u => {
            const safeName = (u.fullName ?? '').replace(/\\/g, '\\\\').replace(/'/g, "\\'");
            return `
        <tr>
            <td class="fw-semibold">${u.fullName ?? ''}</td>
            <td>${u.email ?? ''}</td>
            <td>${u.phoneNumber ?? '\u2014'}</td>
            <td><span class="badge bg-${roleColors[u.role] ?? 'secondary'}">${u.role}</span></td>
            <td>${u.tenantName ?? ''}</td>
            <td>${u.lastLoginAt ? new Date(u.lastLoginAt).toLocaleString() : 'Never'}</td>
            <td>${u.isActive ? '<span class="badge bg-success">Active</span>' : '<span class="badge bg-secondary">Suspended</span>'}</td>
            <td>
                <button class="btn btn-sm btn-outline-primary me-1" onclick='openEditUser(${JSON.stringify(u)})'><i class="bi bi-pencil"></i></button>
                <button class="btn btn-sm btn-outline-warning me-1" onclick="toggleSaUser('${u.id}', ${u.isActive})">${u.isActive ? 'Suspend' : 'Activate'}</button>
                <button class="btn btn-sm btn-outline-danger" onclick="deleteSaUser('${u.id}', '${safeName}')"><i class="bi bi-trash"></i></button>
            </td>
        </tr>`;
        }).join('');
    }
}

async function loadTenants() {
try {
    const res = await fetch('/api/superadmin/tenants');
    if (!res.ok) return;
    allTenants = await res.json();
} catch (e) {
    return;
}
    const sel = document.getElementById('sa-user-tenant');
    sel.innerHTML = '<option value="">Select tenant…</option>' +
        allTenants.map(t => `<option value="${t.id}">${t.name} (${t.slug})</option>`).join('');
}

function openNewUser() {
    document.getElementById('sa-user-id').value = '';
    document.getElementById('sa-user-name').value = '';
    document.getElementById('sa-user-email').value = '';
    document.getElementById('sa-user-phone').value = '';
    document.getElementById('sa-user-role').value = 'agent';
    document.getElementById('sa-user-tenant').value = '';
    document.getElementById('sa-user-password').value = '';
    document.getElementById('sa-user-newpassword').value = '';
    document.getElementById('saUserModalTitle').textContent = 'Add User';
    document.getElementById('sa-password-group').style.display = '';
    document.getElementById('sa-newpassword-group').style.display = 'none';
    document.getElementById('sa-tenant-group').style.display = '';
}

function openEditUser(u) {
    document.getElementById('sa-user-id').value = u.id;
    document.getElementById('sa-user-name').value = u.fullName ?? '';
    document.getElementById('sa-user-email').value = u.email ?? '';
    document.getElementById('sa-user-phone').value = u.phoneNumber ?? '';
    document.getElementById('sa-user-role').value = u.role;
    document.getElementById('sa-user-newpassword').value = '';
    document.getElementById('sa-password-group').style.display = 'none';
    document.getElementById('sa-newpassword-group').style.display = '';
    document.getElementById('sa-tenant-group').style.display = 'none';
    document.getElementById('saUserModalTitle').textContent = 'Edit User';
    new bootstrap.Modal(document.getElementById('saUserModal')).show();
}

async function saveSaUser() {
    const id = document.getElementById('sa-user-id').value;
    const isEdit = !!id;
    const url = isEdit ? `/api/superadmin/users/${id}` : '/api/superadmin/users';
    const method = isEdit ? 'PUT' : 'POST';

    const body = isEdit
        ? {
            fullName: document.getElementById('sa-user-name').value,
            email: document.getElementById('sa-user-email').value,
            phoneNumber: document.getElementById('sa-user-phone').value || null,
            role: document.getElementById('sa-user-role').value,
            newPassword: document.getElementById('sa-user-newpassword').value || null
          }
        : {
            fullName: document.getElementById('sa-user-name').value,
            email: document.getElementById('sa-user-email').value,
            phoneNumber: document.getElementById('sa-user-phone').value || null,
            role: document.getElementById('sa-user-role').value,
            password: document.getElementById('sa-user-password').value,
            tenantId: document.getElementById('sa-user-tenant').value
          };

    const res = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
    if (res.ok || res.status === 201) {
        bootstrap.Modal.getInstance(document.getElementById('saUserModal')).hide();
        load();
    } else {
        try { const err = await res.json(); alert('Error: ' + JSON.stringify(err)); }
        catch { alert('Error: HTTP ' + res.status); }
    }
}

async function toggleSaUser(id, isActive) {
    await fetch(`/api/superadmin/users/${id}/toggle`, { method: 'POST' });
    load();
}

async function deleteSaUser(id, name) {
    if (!confirm(`Delete "${name}"? This cannot be undone.`)) return;
    const res = await fetch(`/api/superadmin/users/${id}`, { method: 'DELETE' });
    if (res.ok || res.status === 204) { load(); }
    else { const err = await res.json(); alert('Error: ' + JSON.stringify(err)); }
}

load();
loadTenants();
</script>
}
