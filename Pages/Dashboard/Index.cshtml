@page "/Dashboard"
@model TelecallingCRM.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Date Range Filter -->
<div class="d-flex justify-content-end align-items-center mb-3 gap-2">
    <label class="form-label mb-0 small fw-semibold me-1">Period:</label>
    <input type="date" id="range-from" class="form-control form-control-sm" style="width:145px;">
    <span class="text-muted small">to</span>
    <input type="date" id="range-to" class="form-control form-control-sm" style="width:145px;">
    <button class="btn btn-primary btn-sm" onclick="loadDashboard()"><i class="bi bi-funnel"></i> Apply</button>
</div>

<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#ede9fe;">
                    <i class="bi bi-person-lines-fill fs-4 text-purple" style="color:#7c3aed;"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Leads</div>
                    <div class="fw-bold fs-4" id="stat-total-leads">-</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#dbeafe;">
                    <i class="bi bi-stars fs-4" style="color:#2563eb;"></i>
                </div>
                <div>
                    <div class="text-muted small">New Leads</div>
                    <div class="fw-bold fs-4" id="stat-new-leads">-</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#d1fae5;">
                    <i class="bi bi-telephone-fill fs-4" style="color:#059669;"></i>
                </div>
                <div>
                    <div class="text-muted small">Calls Today</div>
                    <div class="fw-bold fs-4" id="stat-today-calls">-</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#bbf7d0;">
                    <i class="bi bi-trophy-fill fs-4" style="color:#16a34a;"></i>
                </div>
                <div>
                    <div class="text-muted small">Converted</div>
                    <div class="fw-bold fs-4" id="stat-converted">-</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#d1fae5;">
                    <i class="bi bi-currency-rupee fs-4" style="color:#059669;"></i>
                </div>
                <div>
                    <div class="text-muted small">Revenue Collected</div>
                    <div class="fw-bold fs-4" id="stat-revenue">-</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#fef3c7;">
                    <i class="bi bi-calendar-check-fill fs-4" style="color:#d97706;"></i>
                </div>
                <div>
                    <div class="text-muted small">Follow-ups Today</div>
                    <div class="fw-bold fs-4" id="stat-followups-today">-</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Calls - Last 7 Days</span>
            </div>
            <div class="card-body">
                <canvas id="callsChart" height="100"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header py-3">
                <span class="fw-semibold">Leads by Status</span>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="statusChart" height="200"></canvas>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card">
            <div class="card-header py-3">
                <span class="fw-semibold">Top Agents (This Month)</span>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0" id="agents-table">
                    <thead class="table-light">
                        <tr>
                            <th>Agent</th>
                            <th>Calls</th>
                            <th>Converted</th>
                            <th>Conversion Rate</th>
                        </tr>
                    </thead>
                    <tbody id="agents-tbody">
                        <tr><td colspan="4" class="text-center text-muted py-3">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
    let callsChartInst, statusChartInst;

    // Default date range: current month
    (function () {
        const now = new Date();
        const firstDay = new Date(now.getFullYear(), now.getMonth(), 1);
        document.getElementById('range-from').value = firstDay.toISOString().slice(0,10);
        document.getElementById('range-to').value = now.toISOString().slice(0,10);
    })();

    async function loadDashboard() {
        const from = document.getElementById('range-from').value;
        const to   = document.getElementById('range-to').value;
        let url = '/api/dashboard/stats';
        if (from || to) url += `?from=${from}&to=${to}`;

        const res = await fetch(url);
        if (!res.ok) return;
        const d = await res.json();

        document.getElementById('stat-total-leads').textContent = d.totalLeads;
        document.getElementById('stat-new-leads').textContent = d.newLeads;
        document.getElementById('stat-today-calls').textContent = d.todayCalls;
        document.getElementById('stat-converted').textContent = d.convertedLeads;

        // Revenue from payments
        const payRes = await fetch('/api/payments?pageSize=1000');
        if (payRes.ok) {
            const pd = await payRes.json();
            const total = (pd.items ?? [])
                .filter(p => p.status === 'Captured')
                .reduce((s, p) => s + p.amount, 0);
            document.getElementById('stat-revenue').textContent =
                total.toLocaleString('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 });
        }

        // Follow-ups due today
        const fuRes = await fetch('/api/followups/today');
        if (fuRes.ok) {
            const fuData = await fuRes.json();
            document.getElementById('stat-followups-today').textContent = Array.isArray(fuData) ? fuData.length : '-';
        }

        // Calls chart
        if (callsChartInst) callsChartInst.destroy();
        callsChartInst = new Chart(document.getElementById('callsChart'), {
            type: 'bar',
            data: {
                labels: d.callsLast7Days.map(x => new Date(x.date).toLocaleDateString()),
                datasets: [{ label: 'Calls', data: d.callsLast7Days.map(x => x.count), backgroundColor: '#818cf8', borderRadius: 6 }]
            },
            options: { plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
        });

        // Status donut chart
        if (statusChartInst) statusChartInst.destroy();
        const statusColors = { New:'#3b82f6', Contacted:'#f59e0b', Interested:'#10b981', NotInterested:'#ef4444', FollowUp:'#8b5cf6', Converted:'#22c55e', Dead:'#94a3b8' };
        statusChartInst = new Chart(document.getElementById('statusChart'), {
            type: 'doughnut',
            data: {
                labels: d.leadsByStatus.map(x => x.status),
                datasets: [{ data: d.leadsByStatus.map(x => x.count), backgroundColor: d.leadsByStatus.map(x => statusColors[x.status] ?? '#94a3b8') }]
            },
            options: { plugins: { legend: { position: 'bottom' } }, cutout: '70%' }
        });

        // Agents table
        const tbody = document.getElementById('agents-tbody');
        if (d.topAgents.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">No data yet</td></tr>';
        } else {
            tbody.innerHTML = d.topAgents.map(a => {
                const rate = a.callCount > 0 ? ((a.convertedCount / a.callCount) * 100).toFixed(1) : '0.0';
                return `<tr><td>${a.fullName}</td><td>${a.callCount}</td><td>${a.convertedCount}</td><td>${rate}%</td></tr>`;
            }).join('');
        }
    }

    loadDashboard();

    // Refresh dashboard on SignalR DashboardUpdated event
    document.addEventListener('crm:dashboard-updated', loadDashboard);
    </script>
}
