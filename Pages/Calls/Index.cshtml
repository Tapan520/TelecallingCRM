@page
@model TelecallingCRM.Pages.Calls.IndexModel
@{
    ViewData["Title"] = "Call Log";
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Lead</th><th>Agent</th><th>Date</th>
                    <th>Duration</th><th>Outcome</th><th>Sentiment</th><th>Summary</th>
                </tr>
            </thead>
            <tbody id="calls-tbody">
                <tr><td colspan="7" class="text-center text-muted py-4">Loading...</td></tr>
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
        <small class="text-muted" id="calls-count"></small>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary btn-sm" id="btn-prev" onclick="changePage(-1)">&#8592; Prev</button>
            <button class="btn btn-outline-secondary btn-sm" id="btn-next" onclick="changePage(1)">Next &#8594;</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
let currentPage = 1;
const pageSize = 25;

const outcomeLabels = ['No Answer','Busy','Callback','Interested','Not Interested','Converted','Wrong Number','Other'];
const sentimentColor = s => s === 'positive' ? 'success' : s === 'negative' ? 'danger' : 'secondary';

async function loadCalls() {
    const res = await fetch(`/api/calls?page=${currentPage}&pageSize=${pageSize}`);
    if (!res.ok) return;
    const data = await res.json();

    document.getElementById('calls-tbody').innerHTML = data.calls.map(c => `
        <tr>
            <td><span class="fw-semibold">${c.lead}</span><br><small class="text-muted">${c.leadPhone}</small></td>
            <td>${c.agent}</td>
            <td>${new Date(c.startedAt).toLocaleString()}</td>
            <td>${c.durationSeconds > 0 ? Math.floor(c.durationSeconds/60)+'m '+(c.durationSeconds%60)+'s' : '-'}</td>
            <td><span class="badge bg-secondary">${outcomeLabels[c.outcome] ?? c.outcome}</span></td>
            <td>${c.aiSentiment ? `<span class="badge bg-${sentimentColor(c.aiSentiment)}">${c.aiSentiment}</span>` : '-'}</td>
            <td><small class="text-muted">${c.aiSummary ? c.aiSummary.slice(0, 80) + (c.aiSummary.length > 80 ? '...' : '') : '-'}</small></td>
        </tr>`).join('');

    document.getElementById('calls-count').textContent = `${data.total} calls`;
    document.getElementById('btn-prev').disabled = currentPage <= 1;
    document.getElementById('btn-next').disabled = currentPage * pageSize >= data.total;
}

function changePage(dir) { currentPage += dir; loadCalls(); }

loadCalls();
</script>
}
