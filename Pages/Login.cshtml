@page
@attribute [Microsoft.AspNetCore.RateLimiting.EnableRateLimiting("login")]
@model TelecallingCRM.Pages.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Sign In";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In - TelecallingCRM</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background: linear-gradient(135deg,#1e1b4b 0%,#312e81 60%,#4338ca 100%); min-height:100vh; display:flex; align-items:center; justify-content:center; }
        .login-card { background:#fff; border-radius:1rem; padding:2.5rem; width:100%; max-width:420px; box-shadow:0 20px 60px rgba(0,0,0,0.3); }
        .brand { font-size:1.5rem; font-weight:800; color:#4f46e5; margin-bottom:0.25rem; }
        .form-control:focus { border-color:#4f46e5; box-shadow:0 0 0 0.2rem rgba(79,70,229,0.2); }
        .btn-primary { background:#4f46e5; border-color:#4f46e5; }
        .btn-primary:hover { background:#3730a3; border-color:#3730a3; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="brand"><i class="bi bi-telephone-fill"></i> TelecallingCRM</div>
        <p class="text-muted mb-4" style="font-size:0.875rem;">Multi-tenant Telecalling Platform</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post">
            <div class="mb-3">
                <label class="form-label fw-semibold">Email</label>
                <input asp-for="Input.Email" class="form-control" placeholder="you@company.com" autocomplete="email" />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <label class="form-label fw-semibold">Password</label>
                    <a href="/ForgotPassword" class="text-muted small">Forgot password?</a>
                </div>
                <input asp-for="Input.Password" class="form-control" placeholder="Enter your password" type="password" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2">Sign In</button>
        </form>
        <hr class="my-3" />
        <div class="text-center">
            <small class="text-muted">New organization? <a href="/Register">Create account</a></small>
        </div>
    </div>
</body>
</html>
