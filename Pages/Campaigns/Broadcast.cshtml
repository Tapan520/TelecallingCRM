@page
@model TelecallingCRM.Pages.Campaigns.BroadcastModel
@{
    ViewData["Title"] = "Campaign Broadcast";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-0 fw-bold"><i class="bi bi-broadcast text-primary me-2"></i>Campaign Broadcast</h5>
        <small class="text-muted">Send bulk SMS, WhatsApp, or Email to all leads in a campaign</small>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header fw-semibold">Broadcast Setup</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Campaign *</label>
                    <select id="bc-campaign" class="form-select" onchange="onCampaignSelect()">
                        <option value="">-- Select Campaign --</option>
                    </select>
                    <div id="campaign-stats" class="mt-2 small text-muted"></div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Channel *</label>
                    <div class="btn-group w-100">
                        <button type="button" class="btn btn-outline-primary channel-btn" data-ch="sms" onclick="selectChannel('sms',this)">
                            <i class="bi bi-chat-dots"></i> SMS
                        </button>
                        <button type="button" class="btn btn-outline-success channel-btn" data-ch="whatsapp" onclick="selectChannel('whatsapp',this)">
                            <i class="bi bi-whatsapp"></i> WhatsApp
                        </button>
                        <button type="button" class="btn btn-outline-warning channel-btn" data-ch="email" onclick="selectChannel('email',this)">
                            <i class="bi bi-envelope"></i> Email
                        </button>
                    </div>
                </div>
                <div id="email-subject-wrap" class="mb-3 d-none">
                    <label class="form-label fw-semibold">Email Subject *</label>
                    <input type="text" id="bc-subject" class="form-control" placeholder="e.g. Special Offer for You!">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Message *</label>
                    <textarea id="bc-message" class="form-control font-monospace" rows="5"
                        placeholder="Hi {{name}}, we have a special offer for you! — {{company}}"
                        oninput="updatePreview()"></textarea>
                    <div class="form-text">Variables: <code>{{name}}</code> <code>{{phone}}</code> <code>{{company}}</code></div>
                </div>
                <div class="d-grid">
                    <button class="btn btn-primary" onclick="sendBroadcast()" id="bc-send-btn" disabled>
                        <i class="bi bi-send-fill me-1"></i>Send Broadcast
                    </button>
                </div>
                <div id="bc-result" class="mt-3 d-none"></div>
            </div>
        </div>
    </div>
    <div class="col-lg-7">
        <!-- Preview -->
        <div class="card mb-3">
            <div class="card-header fw-semibold">Live Preview <small class="text-muted">(with sample data)</small></div>
            <div class="card-body">
                <div class="d-flex gap-3">
                    <div id="preview-sms" class="bg-light rounded-4 p-3 flex-grow-1 small font-monospace" style="min-height:80px;white-space:pre-wrap;">Preview will appear here...</div>
                </div>
            </div>
        </div>
        <!-- Send history / recent broadcasts -->
        <div class="card">
            <div class="card-header fw-semibold">Recent Broadcasts</div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light"><tr><th>Campaign</th><th>Channel</th><th>Sent</th><th>Time</th></tr></thead>
                    <tbody id="bc-history-tbody">
                        <tr><td colspan="4" class="text-center text-muted py-3">No recent broadcasts</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let selectedChannel = '';
let broadcastHistory = JSON.parse(localStorage.getItem('broadcastHistory') || '[]');

async function loadCampaigns() {
    const res = await fetch('/api/campaigns?pageSize=100&status=1');
    if (!res.ok) return;
    const d = await res.json();
    const sel = document.getElementById('bc-campaign');
    (d.campaigns ?? []).forEach(c => {
        const o = document.createElement('option');
        o.value = c.id; o.textContent = `${c.name} (${c.leadCount} leads)`;
        o.dataset.leadCount = c.leadCount;
        o.dataset.script = c.script ?? '';
        sel.appendChild(o);
    });
}

async function onCampaignSelect() {
    const sel = document.getElementById('bc-campaign');
    const opt = sel.selectedOptions[0];
    const id = sel.value;
    if (!id) { document.getElementById('campaign-stats').textContent = ''; document.getElementById('bc-send-btn').disabled = true; return; }

    // Fetch campaign stats
    const res = await fetch(`/api/campaigns/${id}/stats`);
    if (res.ok) {
        const d = await res.json();
        document.getElementById('campaign-stats').innerHTML =
            `<span class="badge bg-primary me-1">${d.totalLeads} leads</span>` +
            `<span class="badge bg-success me-1">${d.converted} converted</span>` +
            `<span class="badge bg-info me-1">${d.totalCalls} calls</span>`;
    }

    // Pre-fill script if available
    const script = opt.dataset.script;
    if (script) document.getElementById('bc-message').value = script;

    updateSendBtn();
    updatePreview();
}

function selectChannel(ch, btn) {
    selectedChannel = ch;
    document.querySelectorAll('.channel-btn').forEach(b => { b.classList.remove('active'); b.classList.add('btn-outline-' + b.dataset.ch.replace('whatsapp','success').replace('sms','primary').replace('email','warning')); });
    btn.classList.add('active');
    document.getElementById('email-subject-wrap').classList.toggle('d-none', ch !== 'email');
    updateSendBtn();
}

function updateSendBtn() {
    const hasCampaign = !!document.getElementById('bc-campaign').value;
    const hasChannel = !!selectedChannel;
    document.getElementById('bc-send-btn').disabled = !(hasCampaign && hasChannel);
}

function updatePreview() {
    const msg = document.getElementById('bc-message').value
        .replace(/\{\{name\}\}/g, 'Rahul Sharma')
        .replace(/\{\{phone\}\}/g, '9876543210')
        .replace(/\{\{company\}\}/g, 'Acme Corp');
    document.getElementById('preview-sms').textContent = msg || 'Preview will appear here...';
}

async function sendBroadcast() {
    const campaignId = document.getElementById('bc-campaign').value;
    const message = document.getElementById('bc-message').value.trim();
    const subject = document.getElementById('bc-subject').value.trim();
    const resultDiv = document.getElementById('bc-result');

    if (!message) { alert('Please enter a message.'); return; }
    if (selectedChannel === 'email' && !subject) { alert('Email subject is required.'); return; }

    const campaignName = document.getElementById('bc-campaign').selectedOptions[0].text;
    if (!confirm(`Send "${selectedChannel}" broadcast to all leads in "${campaignName}"?`)) return;

    const btn = document.getElementById('bc-send-btn');
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Sending...';

    const res = await fetch(`/api/campaigns/${campaignId}/broadcast`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ channel: selectedChannel, message, subject: subject || null })
    });

    btn.disabled = false;
    btn.innerHTML = '<i class="bi bi-send-fill me-1"></i>Send Broadcast';
    resultDiv.classList.remove('d-none', 'alert-success', 'alert-danger');

    if (res.ok) {
        const d = await res.json();
        resultDiv.className = 'alert alert-success mt-3';
        resultDiv.innerHTML = `<i class="bi bi-check-circle-fill me-1"></i>Broadcast queued! <strong>${d.queued}</strong> messages via <strong>${d.channel}</strong>.`;

        // Save to local history
        broadcastHistory.unshift({ campaign: campaignName, channel: selectedChannel, queued: d.queued, time: new Date().toLocaleString() });
        broadcastHistory = broadcastHistory.slice(0, 10);
        localStorage.setItem('broadcastHistory', JSON.stringify(broadcastHistory));
        renderHistory();
    } else {
        const err = await res.text();
        resultDiv.className = 'alert alert-danger mt-3';
        resultDiv.innerHTML = `<i class="bi bi-x-circle-fill me-1"></i>Error: ${err}`;
    }
}

function renderHistory() {
    const tbody = document.getElementById('bc-history-tbody');
    if (!broadcastHistory.length) { tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">No recent broadcasts</td></tr>'; return; }
    const chColors = { sms: 'primary', whatsapp: 'success', email: 'warning' };
    tbody.innerHTML = broadcastHistory.map(h => `
        <tr>
            <td class="small fw-semibold">${h.campaign}</td>
            <td><span class="badge bg-${chColors[h.channel]??'secondary'}">${h.channel}</span></td>
            <td><span class="badge bg-light text-dark border">${h.queued} msgs</span></td>
            <td><small class="text-muted">${h.time}</small></td>
        </tr>`).join('');
}

document.getElementById('bc-message').addEventListener('input', updatePreview);
loadCampaigns();
renderHistory();
</script>
}
