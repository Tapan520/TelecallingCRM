@page "{leadId:guid}"
@model TelecallingCRM.Pages.Leads.TimelineModel
@{
    ViewData["Title"] = "Lead Timeline";
}

<div id="timeline-container">
    <div class="text-center text-muted py-5"><div class="spinner-border text-primary"></div><div class="mt-2">Loading timeline...</div></div>
</div>

@section Scripts {
<script>
const leadId = '@Model.LeadId';
const outcomeColors = { NoAnswer:'secondary', Busy:'warning', Callback:'info', Interested:'success',
    NotInterested:'danger', Converted:'success', WrongNumber:'dark', SwitchOff:'secondary',
    HotLead:'warning', CallLater:'info', Other:'secondary' };
const channelIcons = ['bi-telephone','bi-whatsapp','bi-chat-dots','bi-envelope','bi-people','bi-three-dots'];

async function loadTimeline() {
    const res = await fetch(`/api/timeline/${leadId}`);
    if (!res.ok) { document.getElementById('timeline-container').innerHTML = '<div class="alert alert-danger">Lead not found.</div>'; return; }
    const d = await res.json();
    const lead = d.lead;

    // Build merged sorted timeline
    const items = [
        ...d.calls.map(c => ({ ...c, _type: 'call', _time: c.startedAt })),
        ...d.followups.map(f => ({ ...f, _type: 'followup', _time: f.scheduledAt })),
        ...d.tasks.map(t => ({ ...t, _type: 'task', _time: t.dueAt })),
        ...d.documents.map(doc => ({ ...doc, _type: 'document', _time: doc.uploadedAt })),
        ...d.activities.map(a => ({ ...a, _type: 'activity', _time: a.occurredAt }))
    ].sort((a, b) => new Date(b._time) - new Date(a._time));

    const statusBadge = s => `<span class="badge bg-primary">${s}</span>`;
    const aiScoreColor = s => s >= 70 ? 'success' : s >= 40 ? 'warning' : 'danger';

    document.getElementById('timeline-container').innerHTML = `
    <div class="row g-3 mb-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="fw-bold mb-1">${lead.name}</h5>
                            <div class="text-muted mb-2">${lead.phone} ${lead.email ? 'À ' + lead.email : ''}</div>
                            ${statusBadge(lead.status)}
                        </div>
                        <div class="text-end">
                            <div class="fw-bold text-muted small">AI Score</div>
                            <div class="fs-4 fw-bold text-${aiScoreColor(lead.aiScore)}">${lead.aiScore}/100</div>
                            ${lead.aiInsight ? `<small class="text-muted fst-italic">${lead.aiInsight}</small>` : ''}
                        </div>
                    </div>
                    <div class="text-muted small mt-2">Created ${new Date(lead.createdAt).toLocaleDateString()}</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="row text-center g-2">
                        <div class="col-6 border-end">
                            <div class="fw-bold fs-4">${d.calls.length}</div><div class="text-muted small">Calls</div>
                        </div>
                        <div class="col-6">
                            <div class="fw-bold fs-4">${d.followups.length}</div><div class="text-muted small">Follow-ups</div>
                        </div>
                        <div class="col-6 border-end border-top pt-2">
                            <div class="fw-bold fs-4">${d.tasks.length}</div><div class="text-muted small">Tasks</div>
                        </div>
                        <div class="col-6 border-top pt-2">
                            <div class="fw-bold fs-4">${d.documents.length}</div><div class="text-muted small">Docs</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <h6 class="fw-bold text-muted mb-3 text-uppercase" style="font-size:.75rem;letter-spacing:.06em;">Customer Timeline</h6>
    <div class="timeline">
        ${items.map(item => renderItem(item)).join('')}
    </div>`;
}

function renderItem(item) {
    const time = `<small class="text-muted">${new Date(item._time).toLocaleString()}</small>`;
    if (item._type === 'call') return `
        <div class="timeline-item mb-3 d-flex gap-3">
            <div class="timeline-icon bg-primary text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:36px;height:36px;">
                <i class="bi bi-telephone-fill" style="font-size:.8rem;"></i>
            </div>
            <div class="card flex-grow-1">
                <div class="card-body py-2 px-3">
                    <div class="d-flex justify-content-between">
                        <span class="fw-semibold">Call ù <span class="badge bg-${outcomeColors[item.outcome]}">${item.outcome}</span></span>
                        ${time}
                    </div>
                    <div class="text-muted small mt-1">
                        ${Math.floor(item.durationSeconds/60)}m ${item.durationSeconds%60}s À by ${item.agent}
                        ${item.aiSentiment ? `À Sentiment: <strong>${item.aiSentiment}</strong>` : ''}
                    </div>
                    ${item.aiSummary ? `<div class="text-muted small fst-italic mt-1">${item.aiSummary}</div>` : ''}
                    ${item.notes ? `<div class="small mt-1">${item.notes}</div>` : ''}
                </div>
            </div>
        </div>`;
    if (item._type === 'followup') return `
        <div class="timeline-item mb-3 d-flex gap-3">
            <div class="timeline-icon bg-warning text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:36px;height:36px;">
                <i class="bi bi-calendar-check" style="font-size:.8rem;"></i>
            </div>
            <div class="card flex-grow-1">
                <div class="card-body py-2 px-3">
                    <div class="d-flex justify-content-between">
                        <span class="fw-semibold">Follow-up ù ${['Call','WhatsApp','SMS','Email','Meeting'][item.channel]}</span>
                        ${time}
                    </div>
                    <div class="text-muted small">Status: ${item.status} À Assigned: ${item.assignedTo}</div>
                    ${item.notes ? `<div class="small mt-1">${item.notes}</div>` : ''}
                </div>
            </div>
        </div>`;
    if (item._type === 'task') return `
        <div class="timeline-item mb-3 d-flex gap-3">
            <div class="timeline-icon bg-info text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:36px;height:36px;">
                <i class="bi bi-check2-square" style="font-size:.8rem;"></i>
            </div>
            <div class="card flex-grow-1">
                <div class="card-body py-2 px-3">
                    <div class="d-flex justify-content-between">
                        <span class="fw-semibold">Task: ${item.title}</span>${time}
                    </div>
                    <div class="text-muted small">Status: ${item.status} À Assigned: ${item.assignedTo}</div>
                </div>
            </div>
        </div>`;
    if (item._type === 'document') return `
        <div class="timeline-item mb-3 d-flex gap-3">
            <div class="timeline-icon bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:36px;height:36px;">
                <i class="bi bi-file-earmark" style="font-size:.8rem;"></i>
            </div>
            <div class="card flex-grow-1">
                <div class="card-body py-2 px-3">
                    <div class="d-flex justify-content-between">
                        <span class="fw-semibold"><a href="${item.fileUrl}" target="_blank">${item.fileName}</a></span>${time}
                    </div>
                    <div class="text-muted small">Uploaded by ${item.uploadedBy}</div>
                </div>
            </div>
        </div>`;
    // activity
    return `
        <div class="timeline-item mb-3 d-flex gap-3">
            <div class="timeline-icon bg-light border rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:36px;height:36px;">
                <i class="bi bi-activity text-primary" style="font-size:.8rem;"></i>
            </div>
            <div class="card flex-grow-1">
                <div class="card-body py-2 px-3">
                    <div class="d-flex justify-content-between">
                        <span>${item.summary}</span>${time}
                    </div>
                    <div class="text-muted small">by ${item.by}</div>
                </div>
            </div>
        </div>`;
}

loadTimeline();
</script>
<style>
.timeline { border-left: 2px solid #e2e8f0; padding-left: 1.5rem; margin-left: 18px; }
.timeline-item { position: relative; }
.timeline-icon { position: absolute; left: -2.12rem; top: 4px; }
</style>
}
