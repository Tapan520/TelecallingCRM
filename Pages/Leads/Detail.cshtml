@page "{id:guid}"
@model TelecallingCRM.Pages.Leads.DetailModel
@{
    ViewData["Title"] = "Lead Detail";
}

<div id="lead-detail-root">
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
</div>

<!-- Quick Action Modals -->
<!-- Follow-up Modal -->
<div class="modal fade" id="fuModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-calendar-plus me-2"></i>Schedule Follow-up</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-2">
                    <div class="col-6"><label class="form-label fw-semibold">Date & Time *</label><input type="datetime-local" id="fu-date" class="form-control"></div>
                    <div class="col-6">
                        <label class="form-label fw-semibold">Channel</label>
                        <select id="fu-channel" class="form-select">
                            <option value="0">Call</option><option value="1">WhatsApp</option>
                            <option value="2">SMS</option><option value="3">Email</option><option value="4">Meeting</option>
                        </select>
                    </div>
                    <div class="col-12"><label class="form-label">Notes</label><textarea id="fu-notes" class="form-control" rows="2"></textarea></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-warning" onclick="scheduleFollowUp()"><i class="bi bi-calendar-check"></i> Schedule</button>
            </div>
        </div>
    </div>
</div>

<!-- Task Modal -->
<div class="modal fade" id="taskModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-check2-square me-2"></i>Add Task</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="mb-3"><label class="form-label fw-semibold">Title *</label><input type="text" id="task-title" class="form-control"></div>
                <div class="row g-2">
                    <div class="col-6"><label class="form-label">Priority</label>
                        <select id="task-priority" class="form-select"><option value="0">Low</option><option value="1" selected>Normal</option><option value="2">High</option><option value="3">Urgent</option></select>
                    </div>
                    <div class="col-6"><label class="form-label">Due Date *</label><input type="datetime-local" id="task-due" class="form-control"></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-info text-white" onclick="addTask()"><i class="bi bi-plus-lg"></i> Add Task</button>
            </div>
        </div>
    </div>
</div>

<!-- Note Modal -->
<div class="modal fade" id="noteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title"><i class="bi bi-sticky me-2"></i>Add Note</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <textarea id="note-text" class="form-control" rows="5" placeholder="Write your note here..."></textarea>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" onclick="saveNote()"><i class="bi bi-floppy"></i> Save Note</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Lead Modal -->
<div class="modal fade" id="editLeadModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Edit Lead</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">Full Name *</label><input type="text" id="el-name" class="form-control"></div>
                    <div class="col-md-6"><label class="form-label">Phone *</label><input type="text" id="el-phone" class="form-control"></div>
                    <div class="col-md-6"><label class="form-label">Email</label><input type="email" id="el-email" class="form-control"></div>
                    <div class="col-md-6"><label class="form-label">Company</label><input type="text" id="el-company" class="form-control"></div>
                    <div class="col-md-4"><label class="form-label">Status</label>
                        <select id="el-status" class="form-select">
                            <option value="0">New</option><option value="1">Contacted</option><option value="2">Interested</option>
                            <option value="3">Not Interested</option><option value="4">Follow Up</option><option value="5">Converted</option><option value="6">Dead</option>
                        </select>
                    </div>
                    <div class="col-md-4"><label class="form-label">Priority</label>
                        <select id="el-priority" class="form-select"><option value="0">Normal</option><option value="1">High</option><option value="2">Urgent</option></select>
                    </div>
                    <div class="col-md-4"><label class="form-label">Source</label><input type="text" id="el-source" class="form-control"></div>
                    <div class="col-md-4"><label class="form-label">City</label><input type="text" id="el-city" class="form-control"></div>
                    <div class="col-md-4"><label class="form-label">State</label><input type="text" id="el-state" class="form-control"></div>
                    <div class="col-md-4"><label class="form-label">Next Follow-up</label><input type="datetime-local" id="el-followup" class="form-control"></div>
                    <div class="col-12"><label class="form-label">Tags</label><input type="text" id="el-tags" class="form-control" placeholder="comma-separated"></div>
                    <div class="col-12"><label class="form-label">Notes</label><textarea id="el-notes" class="form-control" rows="3"></textarea></div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" onclick="saveLeadEdits()"><i class="bi bi-check-lg"></i> Save Changes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const leadId = '@Model.LeadId';
const outcomeLabels = ['No Answer','Busy','Callback','Interested','Not Interested','Converted','Wrong Number','HotLead','Switch Off','Call Later','Other'];
const statusNames = ['New','Contacted','Interested','Not Interested','Follow Up','Converted','Dead'];
const statusColors = ['primary','info','success','danger','warning','success','secondary'];

async function loadLead() {
    const [leadRes, timelineRes, payRes] = await Promise.all([
        fetch(`/api/leads/${leadId}`),
        fetch(`/api/timeline/${leadId}`),
        fetch(`/api/payments?leadId=${leadId}&pageSize=100`)
    ]);
    if (!leadRes.ok) { document.getElementById('lead-detail-root').innerHTML = '<div class="alert alert-danger">Lead not found.</div>'; return; }

    const lead = await leadRes.json();
    const tl = timelineRes.ok ? await timelineRes.json() : { calls:[], followups:[], tasks:[], documents:[], activities:[] };
    const payData = payRes.ok ? await payRes.json() : { items: [] };
    const payments = payData.items ?? [];

    const aiColor = lead.aiScore >= 70 ? 'success' : lead.aiScore >= 40 ? 'warning' : 'danger';
    const priorityLabel = ['Normal','High','Urgent'][lead.priority] ?? 'Normal';
    const priorityBadge = lead.priority === 2 ? 'bg-danger' : lead.priority === 1 ? 'bg-warning text-dark' : 'bg-secondary';
    const totalRevenue = payments.filter(p => p.status === 'Captured').reduce((s, p) => s + p.amount, 0);

    ViewData = lead.name;

    document.getElementById('lead-detail-root').innerHTML = `
    <div class="d-flex align-items-center gap-2 mb-4 flex-wrap">
        <a href="/Leads" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
        <h5 class="fw-bold mb-0 flex-grow-1">${lead.name}</h5>
        <span class="badge bg-${statusColors[lead.status]}">${statusNames[lead.status]}</span>
        <span class="badge ${priorityBadge}">${priorityLabel}</span>
        <div class="d-flex gap-2 ms-auto flex-wrap">
            <a href="/Calls/Dialer" class="btn btn-success btn-sm"><i class="bi bi-telephone-fill"></i> Call</a>
            <button class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#fuModal"><i class="bi bi-calendar-check"></i> Follow-up</button>
            <button class="btn btn-info btn-sm text-white" data-bs-toggle="modal" data-bs-target="#taskModal"><i class="bi bi-check2-square"></i> Task</button>
            <button class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#noteModal"><i class="bi bi-sticky"></i> Note</button>
            <button class="btn btn-outline-secondary btn-sm" onclick="openEditLead()" data-bs-toggle="modal" data-bs-target="#editLeadModal"><i class="bi bi-pencil"></i> Edit</button>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <!-- Left: Lead Info Card -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Contact Info</div>
                <div class="card-body">
                    <dl class="row mb-0 small">
                        <dt class="col-5 text-muted">Phone</dt><dd class="col-7"><a href="tel:${lead.phone}">${lead.phone}</a></dd>
                        ${lead.alternatePhone ? `<dt class="col-5 text-muted">Alt Phone</dt><dd class="col-7">${lead.alternatePhone}</dd>` : ''}
                        ${lead.email ? `<dt class="col-5 text-muted">Email</dt><dd class="col-7"><a href="mailto:${lead.email}">${lead.email}</a></dd>` : ''}
                        ${lead.company ? `<dt class="col-5 text-muted">Company</dt><dd class="col-7">${lead.company}</dd>` : ''}
                        ${lead.industry ? `<dt class="col-5 text-muted">Industry</dt><dd class="col-7">${lead.industry}</dd>` : ''}
                        ${lead.city || lead.state ? `<dt class="col-5 text-muted">Location</dt><dd class="col-7">${[lead.city, lead.state].filter(Boolean).join(', ')}</dd>` : ''}
                        ${lead.source ? `<dt class="col-5 text-muted">Source</dt><dd class="col-7">${lead.source}</dd>` : ''}
                        ${lead.nextFollowUpAt ? `<dt class="col-5 text-muted">Next Follow-up</dt><dd class="col-7 text-warning fw-semibold">${new Date(lead.nextFollowUpAt).toLocaleString()}</dd>` : ''}
                        <dt class="col-5 text-muted">Created</dt><dd class="col-7">${new Date(lead.createdAt).toLocaleDateString()}</dd>
                    </dl>
                    ${lead.tags ? `<div class="mt-2">${lead.tags.split(',').map(t => `<span class="badge bg-light text-dark border me-1">${t.trim()}</span>`).join('')}</div>` : ''}
                </div>
            </div>
        </div>
        <!-- Center: AI & Stats -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header fw-semibold"><i class="bi bi-robot me-2 text-primary"></i>AI & Performance</div>
                <div class="card-body">
                    <div class="text-center mb-3">
                        <div class="fs-1 fw-bold text-${aiColor}">${lead.aiScore}</div>
                        <div class="text-muted small">AI Conversion Score / 100</div>
                        <div class="progress mt-2" style="height:8px;"><div class="progress-bar bg-${aiColor}" style="width:${lead.aiScore}%"></div></div>
                    </div>
                    ${lead.aiInsight ? `<div class="alert alert-warning py-2 px-3 small mb-3"><i class="bi bi-lightbulb-fill me-1"></i>${lead.aiInsight}</div>` : ''}
                    <div class="row g-2 text-center">
                        <div class="col-4 border-end"><div class="fw-bold text-primary">${tl.calls?.length ?? 0}</div><div class="text-muted" style="font-size:.75rem;">Calls</div></div>
                        <div class="col-4 border-end"><div class="fw-bold text-warning">${tl.followups?.length ?? 0}</div><div class="text-muted" style="font-size:.75rem;">Follow-ups</div></div>
                        <div class="col-4"><div class="fw-bold text-success">${totalRevenue.toLocaleString('en-IN', {style:'currency',currency:'INR',maximumFractionDigits:0})}</div><div class="text-muted" style="font-size:.75rem;">Revenue</div></div>
                    </div>
                    <div class="mt-3 d-flex justify-content-center">
                        <button class="btn btn-outline-primary btn-sm" onclick="scoreNow()"><i class="bi bi-stars"></i> Re-score with AI</button>
                    </div>
                </div>
            </div>
        </div>
        <!-- Right: Notes -->
        <div class="col-lg-4">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="bi bi-sticky me-2 text-warning"></i>Notes</span>
                </div>
                <div class="card-body">
                    <p class="text-muted small" style="white-space:pre-wrap;">${lead.notes || '<em>No notes yet. Click "Note" to add one.</em>'}</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-tabs mb-3" id="leadDetailTabs">
        <li class="nav-item"><a class="nav-link active" onclick="showTab('timeline',this)">Timeline <span class="badge bg-secondary">${(tl.calls?.length??0)+(tl.followups?.length??0)+(tl.tasks?.length??0)+(tl.activities?.length??0)}</span></a></li>
        <li class="nav-item"><a class="nav-link" onclick="showTab('calls',this)">Calls <span class="badge bg-primary">${tl.calls?.length??0}</span></a></li>
        <li class="nav-item"><a class="nav-link" onclick="showTab('messages',this)">Messages</a></li>
        <li class="nav-item"><a class="nav-link" onclick="showTab('docs',this)">Documents <span class="badge bg-secondary">${tl.documents?.length??0}</span></a></li>
        <li class="nav-item"><a class="nav-link" onclick="showTab('payments',this)">Payments <span class="badge bg-success">${payments.length}</span></a></li>
        <li class="nav-item"><a class="nav-link" onclick="showTab('tasks',this)">Tasks <span class="badge bg-info">${tl.tasks?.length??0}</span></a></li>
    </ul>

    <div id="tab-timeline">${buildTimeline(tl)}</div>
    <div id="tab-calls" class="d-none">${buildCallsTab(tl.calls??[])}</div>
    <div id="tab-messages" class="d-none"><div class="text-center text-muted py-4 small">Loading messages...</div></div>
    <div id="tab-docs" class="d-none">${buildDocsTab(tl.documents??[])}</div>
    <div id="tab-payments" class="d-none">${buildPaymentsTab(payments)}</div>
    <div id="tab-tasks" class="d-none">${buildTasksTab(tl.tasks??[])}</div>
    `;

    // Store lead globally for modals
    window._lead = lead;
    window._tl = tl;
    document.title = lead.name + ' - Lead Detail';
}

function showTab(name, el) {
    document.querySelectorAll('#leadDetailTabs .nav-link').forEach(t => t.classList.remove('active'));
    el.classList.add('active');
    ['timeline','calls','messages','docs','payments','tasks'].forEach(t =>
        document.getElementById('tab-' + t)?.classList.toggle('d-none', t !== name));
    if (name === 'messages') loadMessages();
}

function buildTimeline(tl) {
    const items = [
        ...(tl.calls??[]).map(c => ({...c, _t:'call', _ts: new Date(c.startedAt)})),
        ...(tl.followups??[]).map(f => ({...f, _t:'followup', _ts: new Date(f.scheduledAt)})),
        ...(tl.tasks??[]).map(t => ({...t, _t:'task', _ts: new Date(t.dueAt)})),
        ...(tl.documents??[]).map(d => ({...d, _t:'doc', _ts: new Date(d.uploadedAt)})),
        ...(tl.activities??[]).map(a => ({...a, _t:'activity', _ts: new Date(a.occurredAt)}))
    ].sort((a,b) => b._ts - a._ts);
    if (!items.length) return '<div class="text-center text-muted py-4">No activity yet.</div>';
    const icons = {call:'bi-telephone-fill bg-primary', followup:'bi-calendar-check bg-warning',
        task:'bi-check2-square bg-info', doc:'bi-file-earmark bg-secondary', activity:'bi-activity bg-light border'};
    return `<div class="timeline">${items.map(item => `
        <div class="timeline-item mb-3 d-flex gap-3">
            <div class="timeline-icon text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 ${icons[item._t]}" style="width:34px;height:34px;font-size:.75rem;"><i class="bi ${icons[item._t]?.split(' ')[0]}"></i></div>
            <div class="card flex-grow-1"><div class="card-body py-2 px-3">
                <div class="d-flex justify-content-between">
                    <span class="small fw-semibold">${
                        item._t === 'call' ? `Call — <span class="badge bg-secondary">${outcomeLabels[item.outcome]??item.outcome}</span> by ${item.agent}` :
                        item._t === 'followup' ? `Follow-up via ${['Call','WhatsApp','SMS','Email','Meeting'][item.channel]} — <span class="badge bg-${item.status==='Done'?'success':item.status==='Missed'?'danger':'warning'}">${item.status}</span>` :
                        item._t === 'task' ? `Task: ${item.title} — <span class="badge bg-secondary">${item.status}</span>` :
                        item._t === 'doc' ? `Document: <a href="${item.fileUrl}" target="_blank">${item.fileName}</a>` :
                        item.summary
                    }</span>
                    <small class="text-muted">${item._ts.toLocaleString()}</small>
                </div>
                ${item._t === 'call' && item.aiSummary ? `<div class="text-muted small fst-italic mt-1">${item.aiSummary}</div>` : ''}
                ${item._t === 'call' && item.notes ? `<div class="small mt-1">${item.notes}</div>` : ''}
            </div></div>
        </div>`).join('')}</div>`;
}

function buildCallsTab(calls) {
    if (!calls.length) return '<div class="text-center text-muted py-4">No calls recorded yet.</div>';
    return `<div class="card"><div class="card-body p-0"><table class="table table-hover mb-0">
        <thead class="table-light"><tr><th>Date</th><th>Duration</th><th>Outcome</th><th>Agent</th><th>Sentiment</th><th>Summary</th><th>Audio</th></tr></thead>
        <tbody>${calls.map(c => `<tr>
            <td><small>${new Date(c.startedAt).toLocaleString()}</small></td>
            <td>${Math.floor(c.durationSeconds/60)}m ${c.durationSeconds%60}s</td>
            <td><span class="badge bg-secondary">${outcomeLabels[c.outcome]??c.outcome}</span></td>
            <td>${c.agent}</td>
            <td>${c.aiSentiment ? `<span class="badge bg-${c.aiSentiment==='positive'?'success':c.aiSentiment==='negative'?'danger':'secondary'}">${c.aiSentiment}</span>` : '-'}</td>
            <td><small class="text-muted">${(c.aiSummary||'').slice(0,70)}</small></td>
            <td>${c.audioFileUrl ? `<audio controls style="height:26px;max-width:140px;" src="${c.audioFileUrl}"></audio>` : '-'}</td>
        </tr>`).join('')}</tbody>
    </table></div></div>`;
}

async function loadMessages() {
    const res = await fetch(`/api/inbox/thread/${leadId}`);
    const tab = document.getElementById('tab-messages');
    if (!res.ok) { tab.innerHTML = '<div class="text-center text-muted py-4">No messages found.</div>'; return; }
    const msgs = await res.json();
    if (!msgs.length) { tab.innerHTML = '<div class="text-center text-muted py-4">No messages yet.</div>'; return; }
    const chIcons = {whatsapp:'bi-whatsapp text-success', sms:'bi-chat-dots text-primary', email:'bi-envelope text-warning'};
    tab.innerHTML = `<div class="card"><div class="card-body" style="max-height:500px;overflow-y:auto;">${
        msgs.map(m => `<div class="d-flex gap-2 mb-3 ${m.dir==='outbound'?'flex-row-reverse':''}">
            <div class="rounded-circle bg-light border d-flex align-items-center justify-content-center flex-shrink-0" style="width:32px;height:32px;">
                <i class="bi ${chIcons[m.ch]??'bi-chat'}" style="font-size:.8rem;"></i>
            </div>
            <div class="rounded-3 p-2 px-3 small ${m.dir==='outbound'?'bg-primary text-white':'bg-light'}" style="max-width:70%;">
                ${m.body}
                <div class="mt-1 opacity-75" style="font-size:.7rem;">${new Date(m.ts).toLocaleString()}</div>
            </div>
        </div>`).join('')
    }</div></div>`;
}

function buildDocsTab(docs) {
    if (!docs.length) return '<div class="text-center text-muted py-4">No documents uploaded yet.</div>';
    return `<div class="row g-3">${docs.map(d => `
        <div class="col-md-4"><div class="card"><div class="card-body py-2">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-file-earmark-text fs-4 text-primary"></i>
                <div><div class="fw-semibold small"><a href="${d.fileUrl}" target="_blank">${d.fileName}</a></div>
                <div class="text-muted" style="font-size:.7rem;">${d.uploadedBy} · ${new Date(d.uploadedAt).toLocaleDateString()}</div></div>
            </div>
        </div></div></div>`).join('')}</div>`;
}

function buildPaymentsTab(payments) {
    if (!payments.length) return '<div class="text-center text-muted py-4">No payments recorded.</div>';
    const total = payments.filter(p => p.status==='Captured').reduce((s,p) => s+p.amount, 0);
    return `<div class="alert alert-success py-2 mb-3">Total Collected: <strong>${total.toLocaleString('en-IN',{style:'currency',currency:'INR',maximumFractionDigits:0})}</strong></div>
    <div class="card"><div class="card-body p-0"><table class="table table-hover mb-0">
        <thead class="table-light"><tr><th>Amount</th><th>Status</th><th>Receipt</th><th>Date</th></tr></thead>
        <tbody>${payments.map(p => `<tr>
            <td class="fw-semibold">${p.currency} ${Number(p.amount).toLocaleString('en-IN',{minimumFractionDigits:2})}</td>
            <td><span class="badge bg-${p.status==='Captured'?'success':p.status==='Pending'?'warning text-dark':'secondary'}">${p.status}</span></td>
            <td><small class="text-muted">${p.receiptNumber??p.razorpayOrderId??'—'}</small></td>
            <td><small>${new Date(p.createdAt).toLocaleDateString()}</small></td>
        </tr>`).join('')}</tbody>
    </table></div></div>`;
}

function buildTasksTab(tasks) {
    if (!tasks.length) return '<div class="text-center text-muted py-4">No tasks linked to this lead.</div>';
    const statusC = {Pending:'warning', InProgress:'info', Completed:'success', Overdue:'danger', Cancelled:'secondary'};
    return `<div class="card"><div class="card-body p-0"><table class="table table-hover mb-0">
        <thead class="table-light"><tr><th>Title</th><th>Due</th><th>Assigned</th><th>Status</th></tr></thead>
        <tbody>${tasks.map(t => `<tr>
            <td class="fw-semibold">${t.title}</td>
            <td><small>${new Date(t.dueAt).toLocaleString()}</small></td>
            <td><small>${t.assignedTo}</small></td>
            <td><span class="badge bg-${statusC[t.status]??'secondary'}">${t.status}</span></td>
        </tr>`).join('')}</tbody>
    </table></div></div>`;
}

async function scheduleFollowUp() {
    const body = {
        leadId, scheduledAt: document.getElementById('fu-date').value,
        channel: parseInt(document.getElementById('fu-channel').value),
        notes: document.getElementById('fu-notes').value,
        isRecurring: false, recurrenceRule: null, assignedToId: null
    };
    const res = await fetch('/api/followups', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
    if (res.ok) { bootstrap.Modal.getInstance(document.getElementById('fuModal')).hide(); loadLead(); }
    else alert('Error scheduling follow-up.');
}

async function addTask() {
    const body = {
        title: document.getElementById('task-title').value,
        priority: parseInt(document.getElementById('task-priority').value),
        dueAt: document.getElementById('task-due').value,
        leadId, assignedToId: null, description: null
    };
    const res = await fetch('/api/tasks', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
    if (res.ok) { bootstrap.Modal.getInstance(document.getElementById('taskModal')).hide(); loadLead(); }
    else alert('Error adding task.');
}

async function saveNote() {
    const note = document.getElementById('note-text').value.trim();
    if (!note) return;
    const lead = window._lead;
    const body = {
        name: lead.name, phone: lead.phone, email: lead.email, company: lead.company,
        alternatePhone: lead.alternatePhone, industry: lead.industry, city: lead.city,
        state: lead.state, source: lead.source, tags: lead.tags, priority: lead.priority,
        status: lead.status, nextFollowUpAt: lead.nextFollowUpAt, assignedToId: lead.assignedToId,
        campaignId: lead.campaignId, notes: note
    };
    const res = await fetch(`/api/leads/${leadId}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
    if (res.ok) { bootstrap.Modal.getInstance(document.getElementById('noteModal')).hide(); loadLead(); }
    else alert('Error saving note.');
}

function openEditLead() {
    const l = window._lead;
    if (!l) return;
    document.getElementById('el-name').value = l.name ?? '';
    document.getElementById('el-phone').value = l.phone ?? '';
    document.getElementById('el-email').value = l.email ?? '';
    document.getElementById('el-company').value = l.company ?? '';
    document.getElementById('el-status').value = l.status;
    document.getElementById('el-priority').value = l.priority;
    document.getElementById('el-source').value = l.source ?? '';
    document.getElementById('el-city').value = l.city ?? '';
    document.getElementById('el-state').value = l.state ?? '';
    document.getElementById('el-tags').value = l.tags ?? '';
    document.getElementById('el-notes').value = l.notes ?? '';
    document.getElementById('el-followup').value = l.nextFollowUpAt ? new Date(l.nextFollowUpAt).toISOString().slice(0,16) : '';
}

async function saveLeadEdits() {
    const l = window._lead;
    const body = {
        name: document.getElementById('el-name').value,
        phone: document.getElementById('el-phone').value,
        email: document.getElementById('el-email').value || null,
        company: document.getElementById('el-company').value || null,
        alternatePhone: l.alternatePhone, industry: l.industry,
        city: document.getElementById('el-city').value || null,
        state: document.getElementById('el-state').value || null,
        source: document.getElementById('el-source').value || null,
        tags: document.getElementById('el-tags').value || null,
        notes: document.getElementById('el-notes').value || null,
        status: parseInt(document.getElementById('el-status').value),
        priority: parseInt(document.getElementById('el-priority').value),
        nextFollowUpAt: document.getElementById('el-followup').value || null,
        assignedToId: l.assignedToId, campaignId: l.campaignId
    };
    const res = await fetch(`/api/leads/${leadId}`, { method:'PUT', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
    if (res.ok) { bootstrap.Modal.getInstance(document.getElementById('editLeadModal')).hide(); loadLead(); }
    else { const t = await res.text(); alert('Error: ' + t); }
}

async function scoreNow() {
    const res = await fetch(`/api/leads/${leadId}/score`, { method: 'POST' });
    if (res.ok) loadLead();
}

loadLead();
</script>
