@page
@model TelecallingCRM.Pages.FollowUps.CalendarModel
@{
    ViewData["Title"] = "Follow-up Calendar";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div><h5 class="mb-0 fw-bold"><i class="bi bi-calendar3 text-warning me-2"></i>Follow-up Calendar</h5></div>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        <button class="btn btn-primary btn-sm" onclick="openNewFollowUpModal()">
            <i class="bi bi-plus-lg me-1"></i>New Follow-up
        </button>
        <button class="btn btn-outline-secondary btn-sm" onclick="navigateMonth(-1)"><i class="bi bi-chevron-left"></i></button>
        <span id="month-label" class="fw-semibold mx-1" style="min-width:160px;text-align:center;"></span>
        <button class="btn btn-outline-secondary btn-sm" onclick="navigateMonth(1)"><i class="bi bi-chevron-right"></i></button>
        <button class="btn btn-outline-primary btn-sm ms-1" onclick="goToday()">Today</button>
    </div>
</div>

<!-- Channel Filter Buttons -->
<div class="d-flex gap-2 mb-3 flex-wrap align-items-center">
    <small class="text-muted me-1">Filter:</small>
    <button class="btn btn-sm btn-primary channel-filter active" data-ch="-1" onclick="setFilter(-1,this)">
        <i class="bi bi-grid-fill me-1"></i>All
    </button>
    <button class="btn btn-sm btn-outline-primary channel-filter" data-ch="0" onclick="setFilter(0,this)">
        <i class="bi bi-telephone me-1"></i>Call
    </button>
    <button class="btn btn-sm btn-outline-success channel-filter" data-ch="1" onclick="setFilter(1,this)">
        <i class="bi bi-whatsapp me-1"></i>WhatsApp
    </button>
    <button class="btn btn-sm btn-outline-info channel-filter" data-ch="2" onclick="setFilter(2,this)">
        <i class="bi bi-chat-dots me-1"></i>SMS
    </button>
    <button class="btn btn-sm btn-outline-warning channel-filter" data-ch="3" onclick="setFilter(3,this)">
        <i class="bi bi-envelope me-1"></i>Email
    </button>
    <button class="btn btn-sm btn-outline-secondary channel-filter" data-ch="4" onclick="setFilter(4,this)">
        <i class="bi bi-people me-1"></i>Meeting
    </button>
    <span class="ms-2 badge bg-light text-dark border" id="filter-count"></span>
</div>

<!-- Calendar grid -->
<div class="card">
    <div class="card-body p-0">
        <table class="table table-bordered mb-0" id="cal-table">
            <thead class="table-dark text-center">
                <tr>
                    <th>Sun</th><th>Mon</th><th>Tue</th><th>Wed</th><th>Thu</th><th>Fri</th><th>Sat</th>
                </tr>
            </thead>
            <tbody id="cal-body"></tbody>
        </table>
    </div>
</div>

<!-- Day Detail Offcanvas -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="dayOffcanvas" style="width:420px;">
    <div class="offcanvas-header border-bottom">
        <div>
            <h5 class="offcanvas-title mb-0" id="day-offcanvas-title">Follow-ups</h5>
            <small id="day-offcanvas-subtitle" class="text-muted"></small>
        </div>
        <button class="btn-close" data-bs-dismiss="offcanvas"></button>
    </div>
    <div class="offcanvas-body p-2" id="day-offcanvas-body">
        <div class="text-center text-muted py-4"><div class="spinner-border spinner-border-sm"></div></div>
    </div>
    <div class="offcanvas-footer border-top p-2">
        <button class="btn btn-primary btn-sm w-100" onclick="openNewFollowUpModal(currentDayDate)">
            <i class="bi bi-plus-lg me-1"></i>Add Follow-up for this day
        </button>
    </div>
</div>

<!-- New Follow-up Modal -->
<div class="modal fade" id="fuModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-calendar-plus me-2"></i>New Follow-up</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Lead <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="fu-lead-search" placeholder="Type lead name or phone…" autocomplete="off" oninput="searchLeads(this.value)" />
                    <input type="hidden" id="fu-lead-id" />
                    <div id="fu-lead-results" class="list-group mt-1" style="max-height:160px;overflow-y:auto;position:relative;z-index:10;"></div>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Date & Time <span class="text-danger">*</span></label>
                        <input type="datetime-local" class="form-control" id="fu-date" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Channel</label>
                        <select class="form-select" id="fu-channel">
                            <option value="0">?? Call</option>
                            <option value="1">?? WhatsApp</option>
                            <option value="2">?? SMS</option>
                            <option value="3">?? Email</option>
                            <option value="4">?? Meeting</option>
                        </select>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Notes</label>
                    <textarea class="form-control" id="fu-notes" rows="2" placeholder="Optional notes…"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary btn-sm" onclick="saveFollowUp()">
                    <i class="bi bi-calendar-check me-1"></i>Save Follow-up
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let currentYear  = new Date().getFullYear();
let currentMonth = new Date().getMonth();
let allFollowUps = {};
let activeFilter = -1;     // -1 = show all channels
let currentDayDate = null; // used by "Add Follow-up for this day"

const chColors  = ['primary','success','info','warning','secondary','dark'];
const chNames   = ['Call','WhatsApp','SMS','Email','Meeting','Other'];
const chIcons   = ['bi-telephone','bi-whatsapp','bi-chat-dots','bi-envelope','bi-people','bi-three-dots'];
const statusColors = { Pending:'warning', Done:'success', Missed:'danger', Cancelled:'secondary' };
const statusIcons  = { Pending:'bi-clock', Done:'bi-check-circle-fill', Missed:'bi-x-circle-fill', Cancelled:'bi-dash-circle' };

// ?? Filter ????????????????????????????????????????????????????????????????????
function setFilter(ch, btn) {
    activeFilter = ch;
    document.querySelectorAll('.channel-filter').forEach(b => {
        b.classList.remove('btn-primary','btn-success','btn-info','btn-warning','btn-secondary');
        b.classList.add(`btn-outline-${getChColor(parseInt(b.dataset.ch))}`);
        if (parseInt(b.dataset.ch) === -1) { b.classList.remove('btn-outline-dark'); b.classList.add('btn-outline-primary'); }
    });
    if (ch === -1) { btn.classList.replace('btn-outline-primary','btn-primary'); }
    else { btn.classList.replace(`btn-outline-${chColors[ch]}`, chColors[ch] === 'primary' ? 'btn-primary' : `btn-${chColors[ch]}`); }
    btn.classList.remove('btn-outline-primary','btn-outline-success','btn-outline-info','btn-outline-warning','btn-outline-secondary','btn-outline-dark');
    btn.classList.add(`btn-${ch === -1 ? 'primary' : chColors[ch]}`);
    renderCalendar();
}

function getChColor(ch) { return ch === -1 ? 'primary' : (chColors[ch] ?? 'secondary'); }

function filteredFUs(day) {
    const fus = allFollowUps[day] ?? [];
    return activeFilter === -1 ? fus : fus.filter(f => Number(f.channel) === activeFilter);
}

// ?? Load & Render ?????????????????????????????????????????????????????????????
async function loadMonth() {
    document.getElementById('month-label').textContent =
        new Date(currentYear, currentMonth, 1).toLocaleString('default', { month: 'long', year: 'numeric' });

    const res = await fetch(`/api/followups?pageSize=500`);
    allFollowUps = {};
    if (res.ok) {
        const d = await res.json();
        (d.items ?? []).forEach(f => {
            const dt = new Date(f.scheduledAt);
            if (dt.getFullYear() === currentYear && dt.getMonth() === currentMonth) {
                const key = dt.getDate();
                if (!allFollowUps[key]) allFollowUps[key] = [];
                allFollowUps[key].push(f);
            }
        });
    }
    renderCalendar();
}

function renderCalendar() {
    const firstDay     = new Date(currentYear, currentMonth, 1).getDay();
    const daysInMonth  = new Date(currentYear, currentMonth + 1, 0).getDate();
    const today        = new Date();
    let totalFiltered  = 0;
    const tbody = document.getElementById('cal-body');
    let html = '', day = 1;

    for (let row = 0; row < 6; row++) {
        html += '<tr>';
        for (let col = 0; col < 7; col++) {
            if ((row === 0 && col < firstDay) || day > daysInMonth) {
                html += '<td class="bg-light" style="height:90px;vertical-align:top;min-width:60px;"></td>';
            } else {
                const isToday   = day === today.getDate() && currentMonth === today.getMonth() && currentYear === today.getFullYear();
                const fus       = filteredFUs(day);
                totalFiltered  += fus.length;
                const allForDay = allFollowUps[day] ?? [];
                const badges    = fus.slice(0, 3).map(f => `
                    <div class="badge bg-${chColors[Number(f.channel)]} text-truncate w-100 mb-1"
                         style="cursor:pointer;font-size:.65rem;max-width:100%;" title="${f.leadName} — ${chNames[Number(f.channel)]}">
                        <i class="bi ${chIcons[Number(f.channel)]} me-1"></i>${f.leadName.substring(0, 12)}
                    </div>`).join('');
                const more = fus.length > 3 ? `<small class="text-muted" style="font-size:.65rem;">+${fus.length - 3} more</small>` : '';
                html += `<td style="height:90px;vertical-align:top;cursor:pointer;min-width:60px;" class="${isToday ? 'table-primary' : ''}" onclick="showDay(${day})">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <span class="${isToday ? 'badge bg-primary rounded-circle px-2' : 'fw-semibold small text-muted'}">${day}</span>
                        ${allForDay.length ? `<span class="badge rounded-pill ${isToday ? 'bg-dark' : 'bg-warning text-dark'}" style="font-size:.6rem;">${fus.length}</span>` : ''}
                    </div>
                    ${badges}${more}
                </td>`;
                day++;
            }
        }
        html += '</tr>';
        if (day > daysInMonth) break;
    }
    tbody.innerHTML = html;

    const total = Object.values(allFollowUps).flat().length;
    const countBadge = document.getElementById('filter-count');
    countBadge.textContent = activeFilter === -1
        ? `${total} follow-up${total !== 1 ? 's' : ''} this month`
        : `${totalFiltered} of ${total} shown`;
}

// ?? Day Detail Offcanvas ??????????????????????????????????????????????????????
function showDay(day) {
    const date = new Date(currentYear, currentMonth, day);
    currentDayDate = date;
    document.getElementById('day-offcanvas-title').textContent =
        date.toLocaleDateString('default', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });

    const allForDay = allFollowUps[day] ?? [];
    const fus = activeFilter === -1 ? allForDay : allForDay.filter(f => Number(f.channel) === activeFilter);

    renderDayOffcanvas(fus);
    const oc = bootstrap.Offcanvas.getOrCreateInstance(document.getElementById('dayOffcanvas'));
    oc.show();
}

function renderDayOffcanvas(fus) {
    const body = document.getElementById('day-offcanvas-body');
    const subtitle = document.getElementById('day-offcanvas-subtitle');
    subtitle.textContent = `${fus.length} follow-up${fus.length !== 1 ? 's' : ''}`;

    if (!fus.length) {
        body.innerHTML = `<div class="text-center text-muted py-5">
            <i class="bi bi-calendar-x fs-1 d-block mb-2 opacity-25"></i>
            No follow-ups scheduled for this day.
        </div>`;
        return;
    }

    body.innerHTML = fus.map(f => {
        const ch      = Number(f.channel);
        const phone   = (f.leadPhone ?? '').replace(/\D/g, '');
        const leadUrl = `/Leads/Detail?id=${f.leadId}`;

        // All action buttons — always shown regardless of channel
        const actionBtns = `
            <a href="tel:${f.leadPhone}" class="btn btn-xs btn-outline-primary" title="Call">
                <i class="bi bi-telephone"></i> Call
            </a>
            <a href="https://wa.me/${phone}" target="_blank" class="btn btn-xs btn-outline-success" title="WhatsApp">
                <i class="bi bi-whatsapp"></i> WA
            </a>
            <a href="/Messaging/Sms?leadId=${f.leadId}" class="btn btn-xs btn-outline-info" title="SMS">
                <i class="bi bi-chat-dots"></i> SMS
            </a>
            <a href="/Messaging/Email?leadId=${f.leadId}" class="btn btn-xs btn-outline-warning" title="Email">
                <i class="bi bi-envelope"></i> Email
            </a>`;

        return `<div class="card mb-2 border-start border-4 border-${chColors[ch]}" id="fu-card-${f.id}">
            <div class="card-body py-2 px-3">
                <!-- Header row -->
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <div class="flex-grow-1 me-2">
                        <a href="${leadUrl}" class="fw-semibold text-decoration-none small">${f.leadName}</a>
                        <div class="text-muted" style="font-size:.72rem;">
                            <i class="bi bi-telephone me-1 opacity-50"></i>${f.leadPhone ?? '—'}
                        </div>
                    </div>
                    <div class="text-end flex-shrink-0">
                        <span class="badge bg-${statusColors[f.status] ?? 'secondary'} mb-1">
                            <i class="bi ${statusIcons[f.status] ?? 'bi-circle'} me-1"></i>${f.status}
                        </span>
                    </div>
                </div>

                <!-- Channel + Time row -->
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge bg-${chColors[ch]}">
                        <i class="bi ${chIcons[ch]} me-1"></i>${chNames[ch]}
                    </span>
                    <small class="text-muted">
                        <i class="bi bi-clock me-1 opacity-50"></i>
                        ${new Date(f.scheduledAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                    </small>
                </div>

                <!-- Notes -->
                ${f.notes ? `<div class="text-muted small mb-2 bg-light rounded px-2 py-1">
                    <i class="bi bi-sticky me-1 opacity-50"></i>${f.notes}
                </div>` : ''}

                <!-- Action Buttons -->
                <div class="d-flex gap-1 flex-wrap">
                    ${actionBtns}
                    ${f.status === 'Pending' ? `
                    <button class="btn btn-xs btn-outline-success" onclick="markDone('${f.id}')" title="Mark Done">
                        <i class="bi bi-check-lg"></i> Done
                    </button>
                    <button class="btn btn-xs btn-outline-danger" onclick="cancelFU('${f.id}')" title="Cancel">
                        <i class="bi bi-x-lg"></i>
                    </button>` : ''}
                </div>
            </div>
        </div>`;
    }).join('');
}

// ?? Follow-up Actions ?????????????????????????????????????????????????????????
async function markDone(id) {
    const btn = event.currentTarget;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
    const res = await fetch(`/api/followups/${id}/complete`, { method: 'POST' });
    if (res.ok) {
        // Update local state without full reload
        const card = document.getElementById(`fu-card-${id}`);
        if (card) {
            card.querySelector('.badge.bg-warning')?.classList.replace('bg-warning', 'bg-success');
            const statusBadge = card.querySelector('.badge');
            if (statusBadge) { statusBadge.className = 'badge bg-success mb-1'; statusBadge.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i>Done'; }
            btn.closest('.d-flex')?.querySelectorAll('button')?.forEach(b => b.remove());
        }
        await loadMonth(); // Refresh calendar counts
    } else {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-check-lg"></i> Done';
        alert('Failed to mark as done.');
    }
}

async function cancelFU(id) {
    if (!confirm('Cancel this follow-up?')) return;
    // Call delete endpoint
    const res = await fetch(`/api/followups/${id}`, { method: 'DELETE' });
    if (res.ok) {
        document.getElementById(`fu-card-${id}`)?.remove();
        await loadMonth();
    } else {
        alert('Failed to cancel follow-up.');
    }
}

// ?? New Follow-up Modal ???????????????????????????????????????????????????????
let leadSearchTimer;

function openNewFollowUpModal(date = null) {
    document.getElementById('fu-lead-id').value = '';
    document.getElementById('fu-lead-search').value = '';
    document.getElementById('fu-lead-results').innerHTML = '';
    document.getElementById('fu-notes').value = '';
    document.getElementById('fu-channel').value = '0';

    // Pre-fill date if provided
    if (date) {
        const now = new Date(date);
        now.setHours(10, 0, 0, 0);
        document.getElementById('fu-date').value = now.toISOString().slice(0, 16);
    } else {
        const now = new Date();
        now.setMinutes(0, 0, 0);
        now.setHours(now.getHours() + 1);
        document.getElementById('fu-date').value = now.toISOString().slice(0, 16);
    }
    new bootstrap.Modal(document.getElementById('fuModal')).show();
}

async function searchLeads(q) {
    clearTimeout(leadSearchTimer);
    const results = document.getElementById('fu-lead-results');
    if (q.length < 2) { results.innerHTML = ''; return; }
    leadSearchTimer = setTimeout(async () => {
        const res = await fetch(`/api/leads?search=${encodeURIComponent(q)}&pageSize=8`);
        if (!res.ok) return;
        const d = await res.json();
        if (!d.items?.length) { results.innerHTML = '<div class="list-group-item text-muted small">No leads found.</div>'; return; }
        results.innerHTML = d.items.map(l =>
            `<button type="button" class="list-group-item list-group-item-action py-1 px-2 small"
                onclick="selectLead('${l.id}','${l.name.replace(/'/g,"\\'")}','${l.phone}')">
                <span class="fw-semibold">${l.name}</span>
                <span class="text-muted ms-2">${l.phone}</span>
            </button>`
        ).join('');
    }, 300);
}

function selectLead(id, name, phone) {
    document.getElementById('fu-lead-id').value = id;
    document.getElementById('fu-lead-search').value = `${name} (${phone})`;
    document.getElementById('fu-lead-results').innerHTML = '';
}

async function saveFollowUp() {
    const leadId = document.getElementById('fu-lead-id').value;
    const dateVal = document.getElementById('fu-date').value;
    if (!leadId) { alert('Please select a lead.'); return; }
    if (!dateVal) { alert('Please pick a date and time.'); return; }

    const body = {
        leadId,
        scheduledAt: new Date(dateVal).toISOString(),
        channel: parseInt(document.getElementById('fu-channel').value),
        notes: document.getElementById('fu-notes').value || null,
        isRecurring: false,
        recurrenceRule: null,
        assignedToId: null
    };
    const res = await fetch('/api/followups', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body)
    });
    if (res.ok) {
        bootstrap.Modal.getInstance(document.getElementById('fuModal'))?.hide();
        loadMonth();
    } else {
        const err = await res.json().catch(() => ({}));
        alert(err.message ?? 'Failed to save follow-up.');
    }
}

// ?? Navigation ????????????????????????????????????????????????????????????????
function navigateMonth(dir) {
    currentMonth += dir;
    if (currentMonth > 11) { currentMonth = 0; currentYear++; }
    if (currentMonth < 0)  { currentMonth = 11; currentYear--; }
    loadMonth();
}

function goToday() {
    currentYear  = new Date().getFullYear();
    currentMonth = new Date().getMonth();
    loadMonth();
}

// ?? Init ??????????????????????????????????????????????????????????????????????
loadMonth();
</script>
<style>
.btn-xs { padding: .2rem .45rem; font-size: .72rem; line-height: 1.3; }
#cal-table td { transition: background .15s; }
#cal-table td:hover { background: #f8f4ff !important; }
.offcanvas-footer { background: #f8fafc; }
</style>
}

