@page
@model TelecallingCRM.Pages.FollowUps.IndexModel
@{
    ViewData["Title"] = "Follow-ups";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-0 fw-bold">Follow-up Calendar</h5>
        <small class="text-muted">Scheduled callbacks, reminders and recurring follow-ups</small>
    </div>
    <div class="d-flex gap-2">
        <input type="date" id="date-filter" class="form-control form-control-sm" style="width:180px;"
               value="@DateTime.Today.ToString("yyyy-MM-dd")">
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#fuModal">
            <i class="bi bi-calendar-plus"></i> Schedule
        </button>
    </div>
</div>

<div class="row g-3 mb-4" id="fu-stats"></div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Lead</th><th>Phone</th><th>Scheduled</th><th>Channel</th><th>Assigned</th><th>Status</th><th>Notes</th><th></th></tr>
            </thead>
            <tbody id="fu-tbody">
                <tr><td colspan="8" class="text-center text-muted py-4">Loading...</td></tr>
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
        <small class="text-muted" id="fu-count"></small>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary btn-sm" id="fu-btn-prev" onclick="fuChangePage(-1)" disabled>
                <i class="bi bi-chevron-left"></i> Prev
            </button>
            <button class="btn btn-outline-secondary btn-sm" id="fu-btn-next" onclick="fuChangePage(1)">
                Next <i class="bi bi-chevron-right"></i>
            </button>
        </div>
    </div>
</div>

<!-- Schedule Modal -->
<div class="modal fade" id="fuModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Schedule Follow-up</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
            <div class="modal-body">
                <div class="mb-3 position-relative">
                    <label class="form-label fw-semibold">Lead *</label>
                    <input type="text" id="fu-lead-search" class="form-control" placeholder="Search lead name or phone..." oninput="searchFuLeads(this.value)" autocomplete="off">
                    <input type="hidden" id="fu-lead">
                    <div id="fu-lead-suggestions" class="list-group position-absolute w-100 shadow" style="z-index:1050;display:none;max-height:200px;overflow-y:auto;"></div>
                </div>
                <div class="row g-2">
                    <div class="col-6"><label class="form-label">Date & Time *</label><input type="datetime-local" id="fu-date" class="form-control"></div>
                    <div class="col-6">
                        <label class="form-label">Channel</label>
                        <select id="fu-channel" class="form-select">
                            <option value="0">Call</option><option value="1">WhatsApp</option>
                            <option value="2">SMS</option><option value="3">Email</option>
                            <option value="4">Meeting</option>
                        </select>
                    </div>
                </div>
                <div class="mb-3 mt-2"><label class="form-label">Notes</label><textarea id="fu-notes" class="form-control" rows="2"></textarea></div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="fu-recurring">
                    <label class="form-check-label" for="fu-recurring">Recurring</label>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" onclick="scheduleFollowUp()">Schedule</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const channelIcons = ['bi-telephone','bi-whatsapp','bi-chat-dots','bi-envelope','bi-people'];
const channelNames = ['Call','WhatsApp','SMS','Email','Meeting'];
const statusColors = { Pending:'warning', Done:'success', Missed:'danger', Cancelled:'secondary' };
let fuPage = 1;
const fuPageSize = 25;

async function loadFollowUps() {
    const date = document.getElementById('date-filter').value;
    const res = await fetch(`/api/followups?date=${date}&page=${fuPage}&pageSize=${fuPageSize}`);
    if (!res.ok) return;
    const data = await res.json();

    document.getElementById('fu-count').textContent = `${data.total} follow-up(s)`;
    document.getElementById('fu-btn-prev').disabled = fuPage <= 1;
    document.getElementById('fu-btn-next').disabled = fuPage * fuPageSize >= data.total;

    document.getElementById('fu-tbody').innerHTML = !data.items.length
        ? '<tr><td colspan="8" class="text-center text-muted py-4">No follow-ups for this date.</td></tr>'
        : data.items.map(f => `
        <tr>
            <td class="fw-semibold">${f.leadName}</td>
            <td>${f.leadPhone}</td>
            <td>${new Date(f.scheduledAt).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})}</td>
            <td><i class="bi ${channelIcons[f.channel]}"></i> ${channelNames[f.channel]}</td>
            <td>${f.assignedTo}</td>
            <td><span class="badge bg-${statusColors[f.status] ?? 'secondary'}">${f.status}</span></td>
            <td><small>${f.notes ?? ''}</small></td>
            <td>
                <div class="d-flex gap-1 flex-wrap">
                ${f.channel === 0 ? `<a href="tel:${f.leadPhone}" class="btn btn-sm btn-outline-primary" title="Call"><i class="bi bi-telephone"></i></a>` : ''}
                ${f.channel === 1 ? `<a href="https://wa.me/${f.leadPhone.replace(/\D/g,'')}" target="_blank" class="btn btn-sm btn-outline-success" title="WhatsApp"><i class="bi bi-whatsapp"></i></a>` : ''}
                ${f.channel === 2 ? `<a href="sms:${f.leadPhone}" class="btn btn-sm btn-outline-info" title="SMS"><i class="bi bi-chat-dots"></i></a>` : ''}
                ${f.channel === 3 ? `<a href="/Messaging/Email?leadId=${f.leadId}" class="btn btn-sm btn-outline-warning" title="Email"><i class="bi bi-envelope"></i></a>` : ''}
                ${f.channel === 4 ? `<a href="/Meetings?leadId=${f.leadId}" class="btn btn-sm btn-outline-secondary" title="Meeting"><i class="bi bi-people"></i></a>` : ''}
                ${f.status === 'Pending' ? `<button class="btn btn-sm btn-outline-success" onclick="complete('${f.id}')" title="Mark Done"><i class="bi bi-check-lg"></i></button>` : ''}
                </div>
            </td>
        </tr>`).join('');
}

function fuChangePage(dir) {
    fuPage += dir;
    loadFollowUps();
}

async function scheduleFollowUp() {
    const leadId = document.getElementById('fu-lead').value;
    if (!leadId) { alert('Please select a lead.'); return; }
    const body = {
        leadId: leadId,
        scheduledAt: document.getElementById('fu-date').value,
        channel: parseInt(document.getElementById('fu-channel').value),
        notes: document.getElementById('fu-notes').value,
        isRecurring: document.getElementById('fu-recurring').checked,
        recurrenceRule: null, assignedToId: null
    };
    const res = await fetch('/api/followups', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) });
    if (res.ok) { bootstrap.Modal.getInstance(document.getElementById('fuModal')).hide(); loadFollowUps(); }
    else alert('Error scheduling follow-up');
}

let fuLeadTimer;
function searchFuLeads(q) {
    clearTimeout(fuLeadTimer);
    const box = document.getElementById('fu-lead-suggestions');
    if (q.length < 2) { box.style.display = 'none'; return; }
    fuLeadTimer = setTimeout(async () => {
        const r = await fetch(`/api/leads?q=${encodeURIComponent(q)}&pageSize=8`);
        if (!r.ok) return;
        const d = await r.json();
        const items = d.leads ?? d.items ?? [];
        if (!items.length) { box.style.display = 'none'; return; }
        box.innerHTML = items.map(l =>
            `<a href="javascript:void(0)" class="list-group-item list-group-item-action small" onclick="selectFuLead('${l.id}','${l.name.replace(/'/g,"\\'")}','${l.phone}')">
                <strong>${l.name}</strong> <span class="text-muted">${l.phone}</span>
            </a>`).join('');
        box.style.display = 'block';
    }, 300);
}

function selectFuLead(id, name, phone) {
    document.getElementById('fu-lead').value = id;
    document.getElementById('fu-lead-search').value = `${name} (${phone})`;
    document.getElementById('fu-lead-suggestions').style.display = 'none';
}

async function complete(id) {
    await fetch(`/api/followups/${id}/complete`, { method: 'POST' });
    loadFollowUps();
}

document.getElementById('date-filter').addEventListener('change', () => { fuPage = 1; loadFollowUps(); });
loadFollowUps();
</script>
}
