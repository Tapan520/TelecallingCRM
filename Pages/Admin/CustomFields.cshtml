@page
@model TelecallingCRM.Pages.Admin.CustomFieldsModel
@{
    ViewData["Title"] = "Custom Lead Fields";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="mb-0 fw-bold"><i class="bi bi-layout-text-sidebar-reverse text-primary me-2"></i>Custom Lead Fields</h5>
        <small class="text-muted">Add extra fields to the Lead form for your business needs</small>
    </div>
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#fieldModal" onclick="openFieldModal(null)">
        <i class="bi bi-plus-circle"></i> Add Field
    </button>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:40px;">#</th>
                    <th>Label</th>
                    <th>Field Key</th>
                    <th>Type</th>
                    <th>Required</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody id="fields-tbody">
                <tr><td colspan="6" class="text-center text-muted py-4">Loading...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Field Modal -->
<div class="modal fade" id="fieldModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="field-modal-title">Add Custom Field</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="cf-id">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Display Label *</label>
                    <input type="text" id="cf-label" class="form-control" placeholder="e.g. Loan Amount">
                    <div class="form-text">This appears on the Lead form.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Field Key *</label>
                    <input type="text" id="cf-name" class="form-control" placeholder="e.g. loan_amount">
                    <div class="form-text">Lowercase letters, numbers and underscores only.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Field Type *</label>
                    <select id="cf-type" class="form-select" onchange="toggleDropdownOpts(this.value)">
                        <option value="text">Text</option>
                        <option value="number">Number</option>
                        <option value="date">Date</option>
                        <option value="dropdown">Dropdown</option>
                        <option value="textarea">Textarea</option>
                    </select>
                </div>
                <div id="cf-options-wrap" class="mb-3 d-none">
                    <label class="form-label fw-semibold">Dropdown Options (one per line)</label>
                    <textarea id="cf-options" class="form-control" rows="4" placeholder="Option 1&#10;Option 2&#10;Option 3"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Sort Order</label>
                    <input type="number" id="cf-sort" class="form-control" value="0" min="0">
                </div>
                <div class="form-check">
                    <input type="checkbox" id="cf-required" class="form-check-input">
                    <label class="form-check-label" for="cf-required">Required field</label>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" onclick="saveField()"><i class="bi bi-floppy me-1"></i>Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let allFields = [];

async function loadFields() {
    const res = await fetch('/api/custom-fields');
    if (!res.ok) return;
    allFields = await res.json();
    const tbody = document.getElementById('fields-tbody');
    if (!allFields.length) { tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">No custom fields yet. Add your first one!</td></tr>'; return; }
    const typeIcons = { text:'bi-fonts', number:'bi-123', date:'bi-calendar3', dropdown:'bi-menu-button', textarea:'bi-text-paragraph' };
    tbody.innerHTML = allFields.map((f, i) => `
        <tr>
            <td class="text-muted">${i + 1}</td>
            <td class="fw-semibold">${f.label}</td>
            <td><code class="text-muted">${f.name}</code></td>
            <td><span class="badge bg-light text-dark border"><i class="bi ${typeIcons[f.fieldType]??'bi-input-cursor'} me-1"></i>${f.fieldType}</span></td>
            <td>${f.isRequired ? '<span class="badge bg-danger">Required</span>' : '<span class="badge bg-secondary">Optional</span>'}</td>
            <td class="text-end">
                <button class="btn btn-sm btn-outline-primary me-1" onclick="openFieldModal(${JSON.stringify(f).replace(/"/g,'&quot;')})"><i class="bi bi-pencil"></i></button>
                <button class="btn btn-sm btn-outline-danger" onclick="deleteField('${f.id}')"><i class="bi bi-trash"></i></button>
            </td>
        </tr>`).join('');
}

function toggleDropdownOpts(val) {
    document.getElementById('cf-options-wrap').classList.toggle('d-none', val !== 'dropdown');
}

function openFieldModal(field) {
    const isEdit = !!field;
    document.getElementById('field-modal-title').textContent = isEdit ? 'Edit Field' : 'Add Custom Field';
    document.getElementById('cf-id').value = field?.id ?? '';
    document.getElementById('cf-label').value = field?.label ?? '';
    document.getElementById('cf-name').value = field?.name ?? '';
    document.getElementById('cf-type').value = field?.fieldType ?? 'text';
    document.getElementById('cf-sort').value = field?.sortOrder ?? 0;
    document.getElementById('cf-required').checked = field?.isRequired ?? false;
    const opts = field?.options ? JSON.parse(field.options).join('\n') : '';
    document.getElementById('cf-options').value = opts;
    toggleDropdownOpts(field?.fieldType ?? 'text');
    new bootstrap.Modal(document.getElementById('fieldModal')).show();
}

// Auto-generate field key from label
document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('cf-label')?.addEventListener('input', function() {
        const keyField = document.getElementById('cf-name');
        if (!document.getElementById('cf-id').value) {
            keyField.value = this.value.toLowerCase().replace(/[^a-z0-9]/g, '_').replace(/__+/g, '_');
        }
    });
});

async function saveField() {
    const id = document.getElementById('cf-id').value;
    const type = document.getElementById('cf-type').value;
    let optionsJson = null;
    if (type === 'dropdown') {
        const lines = document.getElementById('cf-options').value.split('\n').map(l => l.trim()).filter(l => l);
        if (!lines.length) { alert('Dropdown must have at least one option.'); return; }
        optionsJson = JSON.stringify(lines);
    }
    const body = {
        name: document.getElementById('cf-name').value.trim(),
        label: document.getElementById('cf-label').value.trim(),
        fieldType: type,
        options: optionsJson,
        isRequired: document.getElementById('cf-required').checked,
        sortOrder: parseInt(document.getElementById('cf-sort').value) || 0
    };
    if (!body.name || !body.label) { alert('Label and key are required.'); return; }
    const url = id ? `/api/custom-fields/${id}` : '/api/custom-fields';
    const method = id ? 'PUT' : 'POST';
    const res = await fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
    if (!res.ok) { const e = await res.text(); alert('Error: ' + e); return; }
    bootstrap.Modal.getInstance(document.getElementById('fieldModal')).hide();
    loadFields();
}

async function deleteField(id) {
    if (!confirm('Delete this custom field? Existing lead data will be preserved but not displayed.')) return;
    await fetch(`/api/custom-fields/${id}`, { method: 'DELETE' });
    loadFields();
}

loadFields();
</script>
}
