@page
@model TelecallingCRM.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <input type="text" id="users-search" class="form-control form-control-sm" placeholder="Search name or email..." style="width:220px;" oninput="onUsersSearch()">
    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#userModal" onclick="openNew()">
        <i class="bi bi-person-plus"></i> Invite User
    </button>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Name</th><th>Email</th><th>Phone</th><th>Role</th><th>Created</th><th>Last Login</th><th>Status</th><th></th></tr>
            </thead>
            <tbody id="users-tbody">
                <tr><td colspan="8" class="text-center text-muted py-4">Loading...</td></tr>
            </tbody>
        </table>
    </div>
    <div class="card-footer d-flex justify-content-between align-items-center">
        <small class="text-muted" id="users-count"></small>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary btn-sm" id="users-btn-prev" onclick="usersChangePage(-1)" disabled>
                <i class="bi bi-chevron-left"></i> Prev
            </button>
            <button class="btn btn-outline-secondary btn-sm" id="users-btn-next" onclick="usersChangePage(1)">
                Next <i class="bi bi-chevron-right"></i>
            </button>
        </div>
    </div>
</div>

<!-- Edit User Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="edit-user-id">
                <div class="mb-3">
                    <label class="form-label">Full Name *</label>
                    <input type="text" id="edit-user-name" class="form-control">
                </div>
                <div class="mb-3">
                    <label class="form-label">Email *</label>
                    <input type="email" id="edit-user-email" class="form-control">
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone</label>
                    <input type="text" id="edit-user-phone" class="form-control">
                </div>
                <div class="mb-3">
                    <label class="form-label">Role</label>
                    <select id="edit-user-role" class="form-select">
                        <option value="agent">Agent</option>
                        <option value="manager">Manager</option>
                        @if (User.IsInRole("superadmin") || User.IsInRole("admin"))
                        {
                            <option value="admin">Admin</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">New Password <span class="text-muted small">(leave blank to keep current)</span></label>
                    <input type="password" id="edit-user-password" class="form-control" placeholder="Enter new password">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveEditUser()">Save Changes</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="userModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Invite New User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Full Name *</label>
                    <input type="text" id="user-name" class="form-control">
                </div>
                <div class="mb-3">
                    <label class="form-label">Email *</label>
                    <input type="email" id="user-email" class="form-control">
                </div>
                <div class="mb-3">
                    <label class="form-label">Role</label>
                    <select id="user-role" class="form-select">
                        <option value="agent">Agent</option>
                        <option value="manager">Manager</option>
                        @if (User.IsInRole("superadmin") || User.IsInRole("admin"))
                        {
                            <option value="admin">Admin</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Phone</label>
                    <input type="text" id="user-phone" class="form-control">
                </div>
                <div class="mb-3">
                    <label class="form-label">Temporary Password *</label>
                    <input type="password" id="user-password" class="form-control">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="submitUserModal()">Save</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
let usersPage = 1;
const usersPageSize = 25;
let usersSearchTimer;

function onUsersSearch() {
    clearTimeout(usersSearchTimer);
    usersSearchTimer = setTimeout(() => { usersPage = 1; loadUsers(); }, 350);
}

async function loadUsers() {
    const q = document.getElementById('users-search').value;
    let url = `/api/admin/users?page=${usersPage}&pageSize=${usersPageSize}`;
    if (q) url += `&q=${encodeURIComponent(q)}`;
    let res;
    try {
        res = await fetch(url);
    } catch (e) {
        document.getElementById('users-tbody').innerHTML = `<tr><td colspan="8" class="text-center text-danger py-4">Network error: ${e.message}</td></tr>`;
        return;
    }
    if (!res.ok) {
        document.getElementById('users-tbody').innerHTML = `<tr><td colspan="8" class="text-center text-danger py-4">Failed to load users (HTTP ${res.status}). Please refresh the page.</td></tr>`;
        return;
    }
    let data;
    try {
        data = await res.json();
    } catch (e) {
        document.getElementById('users-tbody').innerHTML = `<tr><td colspan="8" class="text-center text-danger py-4">Unexpected server response. Please refresh the page.</td></tr>`;
        return;
    }

    document.getElementById('users-count').textContent = `${data.total} user(s)`;
    document.getElementById('users-btn-prev').disabled = usersPage <= 1;
    document.getElementById('users-btn-next').disabled = usersPage * usersPageSize >= data.total;

    if (!Array.isArray(data.users) || data.users.length === 0) {
        document.getElementById('users-tbody').innerHTML = `<tr><td colspan="8" class="text-center text-muted py-4">No users found. Invite someone to get started.</td></tr>`;
        return;
    }
    const roleColors = { admin:'danger', manager:'warning', agent:'primary', superadmin:'dark' };
    const dash = '\u2014';
    _usersCache = data.users;
    try {
        document.getElementById('users-tbody').innerHTML = data.users.map(u => {
            const safeName = (u.fullName ?? '').replace(/\\/g, '\\\\').replace(/'/g, "\\'");
            return `
            <tr>
                <td class="fw-semibold">${u.fullName ?? ''}</td>
                <td>${u.email ?? ''}</td>
                <td>${u.phoneNumber ?? dash}</td>
                <td><span class="badge bg-${roleColors[u.role] ?? 'secondary'}">${u.role}</span></td>
                <td>${u.createdAt ? new Date(u.createdAt).toLocaleDateString() : dash}</td>
                <td>${u.lastLoginAt ? new Date(u.lastLoginAt).toLocaleString() : 'Never'}</td>
                <td>${u.isActive ? '<span class="badge bg-success">Active</span>' : '<span class="badge bg-secondary">Suspended</span>'}</td>
                <td class="text-end">
                    <button class="btn btn-sm btn-outline-primary me-1" onclick="openEditById('${u.id}')"><i class="bi bi-pencil"></i></button>
                    <button class="btn btn-sm btn-outline-warning me-1" onclick="toggleUser('${u.id}', ${u.isActive})">${u.isActive ? 'Suspend' : 'Activate'}</button>
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteUser('${u.id}', '${safeName}')"><i class="bi bi-trash"></i></button>
                </td>
            </tr>`;
        }).join('');
    } catch (renderErr) {
        document.getElementById('users-tbody').innerHTML = `<tr><td colspan="8" class="text-center text-danger py-4">Render error: ${renderErr.message}</td></tr>`;
    }
}

function usersChangePage(dir) { usersPage += dir; loadUsers(); }

// Store users array for safe id-based edit lookup
let _usersCache = [];

function openEditById(id) {
    const u = _usersCache.find(x => x.id === id);
    if (!u) { alert('User not found. Please refresh.'); return; }
    openEdit(u);
}

function openNew() {
    document.getElementById('user-name').value = '';
    document.getElementById('user-email').value = '';
    document.getElementById('user-phone').value = '';
    document.getElementById('user-role').value = 'agent';
    document.getElementById('user-password').value = '';
}

async function submitUserModal() {
    const body = {
        fullName: document.getElementById('user-name').value,
        email: document.getElementById('user-email').value,
        role: document.getElementById('user-role').value,
        password: document.getElementById('user-password').value
    };
    const res = await fetch('/api/admin/users', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
    if (res.ok || res.status === 201) {
        bootstrap.Modal.getInstance(document.getElementById('userModal')).hide();
        loadUsers();
    } else {
        try { const err = await res.json(); alert('Error: ' + JSON.stringify(err)); }
        catch { alert('Error: HTTP ' + res.status); }
    }
}

function openEdit(u) {
    document.getElementById('edit-user-id').value = u.id;
    document.getElementById('edit-user-name').value = u.fullName ?? '';
    document.getElementById('edit-user-email').value = u.email ?? '';
    document.getElementById('edit-user-phone').value = u.phoneNumber ?? '';
    document.getElementById('edit-user-role').value = u.role;
    document.getElementById('edit-user-password').value = '';
    new bootstrap.Modal(document.getElementById('editUserModal')).show();
}

async function saveEditUser() {
    const id = document.getElementById('edit-user-id').value;
    const newPassword = document.getElementById('edit-user-password').value;
    const body = {
        fullName: document.getElementById('edit-user-name').value,
        email: document.getElementById('edit-user-email').value,
        phoneNumber: document.getElementById('edit-user-phone').value || null,
        role: document.getElementById('edit-user-role').value,
        newPassword: newPassword || null
    };
    const res = await fetch(`/api/admin/users/${id}`, { method: 'PUT', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
    if (res.ok) {
        bootstrap.Modal.getInstance(document.getElementById('editUserModal')).hide();
        loadUsers();
    } else {
        try { const err = await res.json(); alert('Error: ' + JSON.stringify(err)); }
        catch { alert('Error: HTTP ' + res.status); }
    }
}

async function deleteUser(id, name) {
    if (!confirm(`Are you sure you want to delete "${name}"? This action cannot be undone.`)) return;
    const res = await fetch(`/api/admin/users/${id}`, { method: 'DELETE' });
    if (res.ok || res.status === 204) {
        loadUsers();
    } else {
        try { const err = await res.json(); alert('Error: ' + JSON.stringify(err)); }
        catch { alert('Error: HTTP ' + res.status); }
    }
}

async function toggleUser(id, isActive) {
    const res = await fetch(`/api/admin/users/${id}/toggle`, { method: 'POST' });
    if (res.ok) loadUsers();
}

loadUsers();
</script>
}
